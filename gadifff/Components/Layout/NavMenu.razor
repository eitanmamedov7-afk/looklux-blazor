@rendermode InteractiveServer

@* SEARCH INDEX
   NAVIGATION, LOGIN, LOGOUT, COOKIE, DELETE, ACCOUNT, USER, ADMIN, AUTH

   Topic: SHARED NAVIGATION MENU
   Purpose: Shows links based on auth role, logs out users, and handles delete-account confirmation.
   Search keywords: NAVIGATION LOGIN LOGOUT COOKIE DELETE ACCOUNT USER ADMIN AUTH
   When to use it: Show this when explaining web navigation, session state, or delete account.
   Important notes: Delete account removes dependent wardrobe data before deleting the user. *@

@using gadifff.Services
@using Models
@using DBL

@inject IAuthService AuthService
@inject UserDB UserDb
@inject GarmentDB GarmentDb
@inject OutfitDB OutfitDb
@inject OutfitGarmentDB OutfitGarmentDb
@inject NavigationManager Nav

@implements IDisposable

<div class="top-row navbar navbar-dark">
    <div class="d-flex w-100 align-items-center justify-content-between">
        <a class="navbar-brand" href="/">Access</a>
        <button class="btn btn-sm btn-outline-primary d-md-none" @onclick="ToggleNavMenu">
            Navigation
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable">
    <nav class="flex-column mt-3">
        <div class="nav-item">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Home</NavLink>
        </div>

        @if (_currentUser is null)
        {
            <div class="nav-item">
                <NavLink class="nav-link" href="/login">Login</NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="nav-link" href="/register">Get Access</NavLink>
            </div>
        }
        else
        {
            <div class="nav-item">
                <NavLink class="nav-link" href="/closet">Workspace</NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="nav-link" href="/outfits">Recommendations</NavLink>
            </div>

            @if (IsAdmin)
            {
                <div class="nav-item">
                    <NavLink class="nav-link" href="/admin/closets">Customers</NavLink>
                </div>
            }

            <div class="nav-item">
                <a href="" class="nav-link"
                   @onclick="OnLogoutClicked"
                   @onclick:preventDefault="true">
                    Logout
                </a>
            </div>

            <div class="nav-item">
                <a href="" class="nav-link text-danger"
                   @onclick="OpenDeleteAccountDialog"
                   @onclick:preventDefault="true">
                    Delete account
                </a>
            </div>
        }
    </nav>
</div>

@if (_showDeleteAccountDialog && _currentUser != null)
{
    <div class="slot-overlay">
        <div class="slot-panel confirm-modal">
            <div class="fw-bold">Delete account</div>
            <div class="text-muted">
                This will permanently delete your account, garments, and saved outfits. This cannot be undone.
            </div>

            @if (!string.IsNullOrWhiteSpace(_deleteAccountMessage))
            {
                <div class="alert @(_deleteAccountIsError ? "alert-warning" : "alert-success") mb-0">
                    @_deleteAccountMessage
                </div>
            }

            <div class="d-flex justify-content-end gap-2">
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="CloseDeleteAccountDialog"
                        disabled="@_deleteAccountBusy">
                    Cancel
                </button>
                <button class="btn btn-sm btn-danger"
                        @onclick="DeleteAccountConfirmedAsync"
                        disabled="@_deleteAccountBusy">
                    @(_deleteAccountBusy ? "Deleting..." : "Delete account")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool collapseNavMenu = true;
    private User? _currentUser;
    private bool _subscribed;
    private bool _disposed;
    private bool _showDeleteAccountDialog;
    private bool _deleteAccountBusy;
    private bool _deleteAccountIsError;
    private string _deleteAccountMessage = string.Empty;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private bool IsAdmin =>
        _currentUser?.Role?.Equals("admin", StringComparison.OrdinalIgnoreCase) == true;

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!_subscribed)
        {
            AuthService.AuthStateChanged += HandleAuthChanged;
            _subscribed = true;
        }

        await RefreshCurrentUserAsync();
    }

    private void HandleAuthChanged()
    {
        _ = RefreshCurrentUserAsync();
    }

    private async Task RefreshCurrentUserAsync()
    {
        if (_disposed)
            return;

        try
        {
            var currentUser = await AuthService.CurrentUserAsync();
            if (_disposed)
                return;

            await InvokeAsync(() =>
            {
                _currentUser = currentUser;
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException) when (_disposed)
        {
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    // FLOW_LOGOUT_WEB_01: User clicks Logout in the nav menu.
    // This layout is involved because logout is available globally; next step is AuthService.LogoutAsync and navigation home.
    private async Task OnLogoutClicked()
    {
        await AuthService.LogoutAsync();
        _currentUser = null;
        Nav.NavigateTo("/", false);
    }

    // Opens the warning modal before deleting the signed-in account.
    private void OpenDeleteAccountDialog()
    {
        _deleteAccountMessage = string.Empty;
        _deleteAccountIsError = false;
        _showDeleteAccountDialog = true;
    }

    // Closes the account delete modal without changing data.
    private void CloseDeleteAccountDialog()
    {
        if (_deleteAccountBusy)
            return;

        _showDeleteAccountDialog = false;
        _deleteAccountMessage = string.Empty;
        _deleteAccountIsError = false;
    }

    // Deletes the signed-in user and related wardrobe data after confirmation.
    // FLOW_DELETE_ACCOUNT_WEB_02: DeleteAccountConfirmedAsync runs after the user confirms account deletion.
    // This layout is involved because the delete-account button is global; next step is DeleteUserCascadeAsync.
    private async Task DeleteAccountConfirmedAsync()
    {
        if (_currentUser == null || _deleteAccountBusy)
            return;

        _deleteAccountBusy = true;
        _deleteAccountMessage = string.Empty;
        _deleteAccountIsError = false;

        try
        {
            if (IsAdmin && await UserDb.CountByRoleAsync("admin") <= 1)
            {
                _deleteAccountIsError = true;
                _deleteAccountMessage = "Cannot delete the last admin account.";
                return;
            }

            var deleted = await DeleteUserCascadeAsync(_currentUser.UserId);
            if (deleted <= 0)
            {
                _deleteAccountIsError = true;
                _deleteAccountMessage = "Could not delete account.";
                return;
            }

            await AuthService.LogoutAsync();
            _currentUser = null;
            _showDeleteAccountDialog = false;
            Nav.NavigateTo("/", false);
        }
        catch (Exception ex)
        {
            _deleteAccountIsError = true;
            _deleteAccountMessage = $"Delete failed: {ex.Message}";
        }
        finally
        {
            _deleteAccountBusy = false;
        }
    }

    // FLOW_DELETE_ACCOUNT_WEB_03: DeleteUserCascadeAsync deletes outfit links, outfits, and garments before deleting the user.
    // This layout is involved because web self-delete does cascade cleanup here; next step is UserDB.DeleteUserAsync.
    private async Task<int> DeleteUserCascadeAsync(string userId)
    {
        var outfits = await OutfitDb.GetByUserAsync(userId, 2000);
        foreach (var outfit in outfits)
        {
            await OutfitGarmentDb.DeleteByOutfitIdAsync(outfit.OutfitId);
            await OutfitDb.DeleteOutfitAsync(outfit.OutfitId);
        }

        var garments = await GarmentDb.GetByUserAsync(userId);
        foreach (var garment in garments)
            await GarmentDb.DeleteGarmentAsync(garment.GarmentId);

        return await UserDb.DeleteUserAsync(userId);
    }

    public void Dispose()
    {
        _disposed = true;

        if (_subscribed)
        {
            AuthService.AuthStateChanged -= HandleAuthChanged;
            _subscribed = false;
        }
    }
}
