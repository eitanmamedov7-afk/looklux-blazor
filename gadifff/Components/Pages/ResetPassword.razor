@* מה הקובץ עושה: הקובץ מציג מסך או רכיב בלייזור ומחבר בין התצוגה שעל המסך לבין אזור הקוד. *@
@* למה הקובץ נדרש: הוא נדרש כדי שהמשתמש יוכל לבצע פעולה או לראות מידע כחלק מהאתר. *@
@* לאילו חלקים בפרויקט הוא מתחבר: הוא מתחבר לשירותים, למודלים, לניווט ולשכבת הדיבי דרך ההזרקות ואזור הקוד. *@
@* איפה ממשיכים לקרוא את הלוגיקה הקשורה: ממשיכים באזור הקוד שבתחתית הקובץ ובשירותים או במחלקות הדיבי שנקראים ממנו. *@

@*
*@







@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@page "/reset-password"

@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@rendermode InteractiveServer


@* ייבוא מרחו שמות שמאפשר לדף להשתמש במודלם, שירותים או כלים נוספים. *@
@using System.ComponentModel.DataAnnotations

@* ייבוא מרחו שמות שמאפשר לדף להשתמש במודלם, שירותים או כלים נוספים. *@
@using gadifff.Services



@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@inject IAuthService AuthService


@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@inject NavigationManager Nav


@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
<PageTitle>Reset Password</PageTitle>

<div class="page-shell">
    <div class="row justify-content-center mt-1">
        <div class="col-md-6 col-lg-5">
            <h3 class="mb-4">Reset password</h3>


            @* בדיקת תנאי שקובעת איזה מסלול בקוד יפעל לפי המצב הנוכחי. *@
            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @( _isError ? "alert-danger" : "alert-success")" role="alert">
                    @_message
                </div>
            }


            @* בדיקת תנאי שקובעת איזה מסלול בקוד יפעל לפי המצב הנוכחי. *@
            @if (_tokenMissing)
            {
                <div class="alert alert-danger" role="alert">
                    Reset token is missing or invalid.
                </div>

                @* הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת. *@
                <button type="button" class="btn btn-outline-secondary" @onclick="GoToLogin">
                    Back to sign in
                </button>
            }

            @* מסלול תצוגת חלופי כשר התנאי הקודם לא התקיים. *@
            else
            {

                @* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
                <EditForm Model="_model" OnValidSubmit="HandleResetAsync" FormName="reset-password">

                    @* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
                    <DataAnnotationsValidator />

                    @* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">New password</label>

                        @* הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת. *@
                        <InputText type="password" class="form-control" @bind-Value="_model.Password" />

                        @* הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה. *@
                        <ValidationMessage For="@(() => _model.Password)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirm new password</label>

                        @* הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת. *@
                        <InputText type="password" class="form-control" @bind-Value="_model.ConfirmPassword" />

                        @* הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה. *@
                        <ValidationMessage For="@(() => _model.ConfirmPassword)" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                            Update password
                        </button>


                        @* הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת. *@
                        <button type="button" class="btn btn-outline-secondary" @onclick="GoToLogin">
                            Back to sign in
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>



@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@code {
    [SupplyParameterFromQuery(Name = "token")]
    // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
    public string? Token { get; set; }

    private ResetPasswordModel _model = new();
    private string _message = string.Empty;
    private bool _isError;
    private bool _isSubmitting;
    private bool _tokenMissing;
    private string _token = string.Empty;

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    protected override void OnParametersSet()
    {
        _token = Token?.Trim() ?? string.Empty;
        _tokenMissing = string.IsNullOrWhiteSpace(_token);
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task HandleResetAsync()
    {
        _isSubmitting = true;
        _isError = false;
        _message = string.Empty;

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var ok = await AuthService.ResetPasswordAsync(_token, _model.Password);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (!ok)
            {
                _isError = true;
                _message = "Password reset failed. The link may be invalid or expired.";
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            _message = "Password updated successfully. You can now sign in.";
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _isSubmitting = false;
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void GoToLogin()
    {
        Nav.NavigateTo("/login");
    }

    // הגדרת מבנה מרכזי שמרכז נתונים או פעוליות עובר החלק הזה בפרויקט.
    public class ResetPasswordModel
    {
        [Required]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
        public string Password { get; set; } = string.Empty;

        [Required]
        [Compare(nameof(Password), ErrorMessage = "Passwords must match.")]
        // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
