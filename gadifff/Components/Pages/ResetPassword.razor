
@page "/reset-password"

@* SEARCH INDEX
   PASSWORD, RESET, TOKEN, UPDATE, VALIDATE, AUTH

   Topic: RESET PASSWORD PAGE
   Purpose: Accepts reset token/new password and calls AuthService.ResetPasswordAsync.
   Search keywords: PASSWORD RESET TOKEN UPDATE VALIDATE AUTH
   When to use it: Show this after explaining the forgot-password email link.
   Important notes: The token must be protected and unexpired before the password hash changes. *@

@rendermode InteractiveServer


@using System.ComponentModel.DataAnnotations

@using gadifff.Services



@inject IAuthService AuthService


@inject NavigationManager Nav


<PageTitle>Reset Password</PageTitle>

@* Role in project:
   Completes the password reset flow after the user opens the emailed reset link.
   This changes the stored password hash through AuthService. *@
@* Layout:
   Centered reset form with new-password fields when the token exists.
   If the token is missing, the page shows an error and only the back-to-login button. *@
<div class="page-shell">
    <div class="row justify-content-center mt-1">
        <div class="col-md-6 col-lg-5">
            <h3 class="mb-4">Reset password</h3>


            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @( _isError ? "alert-danger" : "alert-success")" role="alert">
                    @_message
                </div>
            }


            @if (_tokenMissing)
            {
                <div class="alert alert-danger" role="alert">
                    Reset token is missing or invalid.
                </div>

                <button type="button" class="btn btn-outline-secondary" @onclick="GoToLogin">
                    Back to sign in
                </button>
            }

            else
            {

                <EditForm Model="_model" OnValidSubmit="HandleResetAsync" FormName="reset-password">

                    <DataAnnotationsValidator />

                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">New password</label>

                        <InputText type="password" class="form-control" @bind-Value="_model.Password" />

                        <ValidationMessage For="@(() => _model.Password)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirm new password</label>

                        <InputText type="password" class="form-control" @bind-Value="_model.ConfirmPassword" />

                        <ValidationMessage For="@(() => _model.ConfirmPassword)" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                            Update password
                        </button>


                        <button type="button" class="btn btn-outline-secondary" @onclick="GoToLogin">
                            Back to sign in
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>



@code {
    // Token comes from the reset email link query string.
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    // Page state for password fields, token validation, and submit status.
    private ResetPasswordModel _model = new();
    private string _message = string.Empty;
    private bool _isError;
    private bool _isSubmitting;
    private bool _tokenMissing;
    private string _token = string.Empty;

    // Function role:
    // Copies and validates the query-string token before the reset form is shown.
    // FLOW_PASSWORD_RESET_WEB_06: User opens the emailed reset link and this page reads the token query string.
    // This page is involved because email links land here; next step is the user submitting the new password form.
    // FLOW_PASSWORD_RESET_MOBILE_08: User opens the reset email that was requested from MAUI, and this same web page reads the token.
    // This page is involved because MAUI reset emails still complete in the browser; next step is submitting the new password form.
    protected override void OnParametersSet()
    {
        _token = Token?.Trim() ?? string.Empty;
        _tokenMissing = string.IsNullOrWhiteSpace(_token);
    }

    // Function role:
    // Sends token + new password to AuthService and reports expired/invalid link errors.
    // FLOW_PASSWORD_RESET_WEB_07: HandleResetAsync submits the web token and new password to AuthService.ResetPasswordAsync.
    // This page is involved because the user confirms the new password here; next step is AuthService token validation and hashing.
    // FLOW_PASSWORD_RESET_MOBILE_09: HandleResetAsync also completes MAUI-started reset emails after the user opens the browser link.
    // This page is involved because both reset paths finish on the same page; next step is AuthService token validation and hashing.
    private async Task HandleResetAsync()
    {
        _isSubmitting = true;
        _isError = false;
        _message = string.Empty;

        try
        {
            var ok = await AuthService.ResetPasswordAsync(_token, _model.Password);
            if (!ok)
            {
                _isError = true;
                _message = "Password reset failed. The link may be invalid or expired.";
                return;
            }

            _message = "Password updated successfully. You can now sign in.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    // Function role:
    // Returns the user to sign in after reset success or invalid token.
    private void GoToLogin()
    {
        Nav.NavigateTo("/login");
    }

    // Data role:
    // Password confirmation payload and validation rules for the reset form.
    public class ResetPasswordModel
    {
        // VALIDATION_PASSWORD: reset-password requires the same minimum password length as register/API.
        [Required]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = string.Empty;

        // VALIDATION_PASSWORD_CONFIRM: reset-password requires the repeated password to match.
        [Required]
        [Compare(nameof(Password), ErrorMessage = "Passwords must match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
