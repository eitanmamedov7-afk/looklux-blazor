
@page "/register"

@rendermode InteractiveServer

@* SEARCH INDEX
   REGISTER, ADD, USER, AUTH, VALIDATE, LOGIN, FORM

   Topic: WEB REGISTER PAGE
   Purpose: Creates a new customer account through AuthService.RegisterAsync.
   Search keywords: REGISTER ADD USER AUTH VALIDATE LOGIN FORM
   When to use it: Show this when explaining browser account creation.
   Important notes: After registration the page logs the user in and navigates into the app. *@


@using System.ComponentModel.DataAnnotations

@using gadifff.Services

@using Models



@inject IAuthService AuthService


@inject NavigationManager Nav


<PageTitle>Get Access</PageTitle>

@* Role in project:
   Public customer account creation page.
   Success here creates a customer user and starts the same closet/outfit flow as login. *@
@* Layout:
   Centered registration form with full name, email, password, confirm password, submit, and back-to-login buttons.
   It only creates customer accounts; admin account creation is handled in AdminClosets.razor. *@
<div class="page-shell">
    <div class="row justify-content-center mt-1">
        <div class="col-md-6 col-lg-5">
            <h3 class="mb-4 text-center">Create customer account</h3>


            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @( _isError ? "alert-danger" : "alert-success")" role="alert">
                    @_message
                </div>
            }


            <EditForm Model="_model"
                      OnValidSubmit="HandleRegisterAsync"
                      FormName="register">
                @* FLOW_REGISTER_WEB_01: User submits the register form; next step is HandleRegisterAsync in this file. *@

                <DataAnnotationsValidator />

                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Full name</label>

                    <InputText class="form-control" @bind-Value="_model.FullName" />

                    <ValidationMessage For="@(() => _model.FullName)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>

                    <InputText class="form-control" @bind-Value="_model.Email" />

                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>

                    <InputText type="password" class="form-control" @bind-Value="_model.Password" />

                    <ValidationMessage For="@(() => _model.Password)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirm password</label>

                    <InputText type="password" class="form-control" @bind-Value="_model.ConfirmPassword" />

                    <ValidationMessage For="@(() => _model.ConfirmPassword)" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        Get Access
                    </button>

                    <button type="button"
                            class="btn btn-outline-secondary"

                            @onclick="GoToLogin">
                        Back to sign in
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>



@code {
    // Page state for the registration form and feedback message.
    private RegisterModel _model = new();
    private string _message = string.Empty;
    private bool _isError;

    // Function role:
    // Validates passwords, creates a customer through AuthService, signs them in, then opens the home page.
    // FLOW_REGISTER_WEB_02: HandleRegisterAsync checks confirm password and calls AuthService.RegisterAsync.
    // This page is involved because web registration starts here; next step is AuthService creating the customer account.
    private async Task HandleRegisterAsync()
    {
        _isError = false;
        _message = string.Empty;

        if (_model.Password != _model.ConfirmPassword)
        {
            _isError = true;
            _message = "Passwords must match.";
            return;
        }

        try
        {
            var ok = await AuthService.RegisterAsync(
                _model.FullName.Trim(),
                _model.Email.Trim(),
                _model.Password,
                "customer");

            if (!ok)
            {
                _isError = true;
                _message = "Registration failed. Email may already exist.";
                return;
            }

            await AuthService.LoginAsync(_model.Email.Trim(), _model.Password);

            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _isError = true;
            _message = "Registration failed: " + ex.Message;
        }
    }

    // Function role:
    // Returns an existing user to the sign-in page.
    private void GoToLogin()
    {
        Nav.NavigateTo("/login");
    }

    // Data role:
    // Form payload and validation rules for customer self-registration.
    public class RegisterModel
    {
        // VALIDATION_NAME: Blazor registration requires a valid first and last name.
        [Required]
        [ValidFullName]
        public string FullName { get; set; } = string.Empty;

        // VALIDATION_EMAIL: Blazor registration requires a valid email address.
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        // VALIDATION_PASSWORD: Blazor registration requires the same 6-128 password length as the API.
        [Required]
        [StringLength(128, MinimumLength = 6, ErrorMessage = "Password must be 6-128 characters.")]
        public string Password { get; set; } = string.Empty;

        // VALIDATION_PASSWORD_CONFIRM: Blazor registration requires the repeated password to match.
        [Required]
        [Compare(nameof(Password), ErrorMessage = "Passwords must match.")]
        public string ConfirmPassword { get; set; } = string.Empty;

    }
}
