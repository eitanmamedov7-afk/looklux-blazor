    private void PrepareManualFallback(byte[] bytes, IBrowserFile file, string sha, string? featureJson, string reason)
    {
        _pendingBytes = bytes;
        _pendingContentType = file.ContentType ?? "image/jpeg";
        _pendingFileName = file.Name ?? "upload.jpg";
        _pendingHash = sha;
        _allowManual = true;
        _isErr = true;
        _msg = $"{reason} Choose the type below to save manually.";
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void ClearPending()
    {
        _pendingBytes = null;
        _pendingContentType = null;
        _pendingFileName = null;
        _pendingHash = null;
        _manualType = "shirt";
        _allowManual = false;
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task SaveManualAsync()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsReadOnlyAdminView)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_pendingBytes == null || _pendingHash == null || _currentUser == null) return;

        _loading = true;
        _loadingText = "Saving manuallyÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¦";
        StateHasChanged();

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await PersistGarmentAsync(
                _manualType,
                color: null,
                colorSecondary: null,
                pattern: null,
                styleCategory: null,
                season: null,
                occasion: null,
                formalityLevel: null,
                styleTags: null,
                fit: null,
                material: null,
                sleeve: _manualType == "shirt" ? null : "none",
                length: null,
                brand: null,
                featureJson: "{}",
                imageBytes: _pendingBytes,
                contentType: _pendingContentType ?? "image/jpeg",
                fileName: _pendingFileName ?? "upload.jpg",
                sha: _pendingHash);

            ClearPending();
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            _isErr = true;
            _msg = ex.Message;
            Log("manual-save-error " + ex.Message);
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _loading = false;
            _loadingText = string.Empty;
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await InvokeAsync(StateHasChanged);
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private IEnumerable<string> RenderTags(string featureJson)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var list = new List<string>();
        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var doc = JsonDocument.Parse(featureJson);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (doc.RootElement.TryGetProperty("style_tags", out var tags) && tags.ValueKind == JsonValueKind.Array)
            {
                // לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים.
                foreach (var t in tags.EnumerateArray())
                {
                    // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
                    var v = t.GetString();
                    // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
                    if (!string.IsNullOrWhiteSpace(v))
                        list.Add(v!);
                }
            }

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (doc.RootElement.TryGetProperty("color", out var c) && c.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(c.GetString()))
                list.Add(c.GetString()!);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (doc.RootElement.TryGetProperty("style_category", out var style) && style.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(style.GetString()))
                list.Add(style.GetString()!);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (doc.RootElement.TryGetProperty("occasion", out var occasion) && occasion.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(occasion.GetString()))
                list.Add(occasion.GetString()!);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (doc.RootElement.TryGetProperty("fit", out var f) && f.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(f.GetString()))
                list.Add(f.GetString()!);
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch
        {
        }

        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return list;
    }

