    // Function role:
    // Deletes the selected garment and reloads the closet after confirmation.
    // FLOW_DELETE_GARMENT_WEB_02: DeleteGarmentConfirmedAsync runs after user confirms the delete modal.
    // This page is involved because the web delete button lives on closet cards; next step is GarmentDB.DeleteGarmentAsync.
    private async Task DeleteGarmentConfirmedAsync()
    {
        if (IsReadOnlyAdminView)
            return;

        if (_currentUser == null || string.IsNullOrWhiteSpace(_deleteGarmentId) || _deleteGarmentDialogBusy)
            return;

        _deleteGarmentDialogBusy = true;
        _deleteGarmentDialogMessage = string.Empty;
        _deleteGarmentDialogIsError = false;
        _deleteGarmentDialogCompleted = false;

        try
        {
            var deleted = await GarmentDb.DeleteGarmentAsync(_deleteGarmentId);
            if (deleted <= 0)
            {
                _deleteGarmentDialogIsError = true;
                _deleteGarmentDialogMessage = "Could not delete this garment.";
                return;
            }

            await ReloadClosetDataAsync();
            _deleteGarmentDialogMessage = "Garment deleted.";
            _deleteGarmentDialogCompleted = true;
        }
        catch (Exception ex)
        {
            _deleteGarmentDialogIsError = true;
            _deleteGarmentDialogMessage = $"Delete failed: {ex.Message}";
        }
        finally
        {
            _deleteGarmentDialogBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // Function role:
    // Computes image hash used by SQL unique duplicate protection.
    private static string Sha256Hex(byte[] bytes)
    {
        using var sha = SHA256.Create();
        var hash = sha.ComputeHash(bytes);
        return Convert.ToHexString(hash).ToLowerInvariant();
    }

    // Function role:
    // Creates the Garment model from AI/manual values and saves it through GarmentDB.
    // FLOW_GARMENT_UPLOAD_WEB_04: PersistGarmentAsync creates the Garment model with AI/manual fields, image bytes, and sha256.
    // This page is involved because it maps parsed upload data to the model; next step is GarmentDB.CreateAsync.
    private async Task<bool> PersistGarmentAsync(
        string type,
        string? color,
        string? colorSecondary,
        string? pattern,
        string? styleCategory,
        string? season,
        string? occasion,
        int? formalityLevel,
        string? styleTags,
        string? fit,
        string? material,
        string? sleeve,
        string? length,
        string? brand,
        string? featureJson,
        byte[] imageBytes,
        string contentType,
        string sha)
    {
        var garmentId = Guid.NewGuid().ToString();

        var g = new Garment
        {
            GarmentId = garmentId,
            OwnerUserId = ActiveUserId,
            Type = type,
            Color = color,
            ColorSecondary = colorSecondary,
            Pattern = pattern,
            StyleCategory = styleCategory,
            Season = season,
            Occasion = occasion,
            FormalityLevel = formalityLevel,
            StyleTags = styleTags,
            Fit = fit,
            Material = material,
            Sleeve = sleeve,
            Length = length,
            Brand = brand,
            FeatureJson = featureJson,
            ImageBytes = imageBytes,
            ImageMimeType = contentType,
            Sha256 = sha,
            CreatedAt = DateTime.UtcNow
        };

        var inserted = await GarmentDb.CreateAsync(g);
        if (inserted <= 0)
        {
            Log("db-insert failed " + (GarmentDb.LastError ?? ""));
            throw new Exception(string.IsNullOrWhiteSpace(GarmentDb.LastError)
                ? "Failed to add garment."
                : $"Failed to add garment: {GarmentDb.LastError}");
        }
        else
        {
            Log($"db-insert ok garmentId={garmentId}");
        }

        await ReloadClosetDataAsync();
        _msg = "Added!";
        _isErr = false;
        return true;
    }

