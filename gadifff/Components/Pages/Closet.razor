    // הסבר: פונקציית בנייה. מרכיבה אובייקט/בקשה/פלט מתוך נתוני קלט לפני השלב הבא בזרימה.
    private GarmentFilterRequest BuildGarmentFilterRequest() =>
        new()
        {
            Categories = _selectedCategories.Select(x => x.ToLowerInvariant()).ToList(),
            Subcategories = _selectedSubcategories.Select(x => x.ToLowerInvariant()).ToList(),
            Colors = _selectedColors.Select(x => x.ToLowerInvariant()).ToList(),
            Seasons = _selectedSeasons.Select(x => x.ToLowerInvariant()).ToList(),
            Materials = _selectedMaterials.Select(x => x.ToLowerInvariant()).ToList(),
            Brands = _selectedBrands.Select(x => x.ToLowerInvariant()).ToList(),
            Fits = _selectedFits.Select(x => x.ToLowerInvariant()).ToList(),
            Patterns = _selectedPatterns.Select(x => x.ToLowerInvariant()).ToList(),
            Tags = _selectedTags.Select(x => x.ToLowerInvariant()).ToList()
        };

    // הסבר: פונקציה זו היא חלק מזרימת הקובץ: קלט -> עיבוד -> תוצאה/עדכון מצב.
    private async Task RefreshClosetFiltersAsync(bool debounce)
    {
        if (_currentUser == null || string.IsNullOrWhiteSpace(ActiveUserId))
            return;

        _filterCts?.Cancel();
        var cts = new CancellationTokenSource();
        _filterCts = cts;

        try
        {
            if (debounce)
                await Task.Delay(180, cts.Token);

            _filtersBusy = true;
            await InvokeAsync(StateHasChanged);

            var request = BuildGarmentFilterRequest();
            _filteredItems = await GarmentDb.GetFilteredByUserAsync(ActiveUserId, request);
            if (cts.IsCancellationRequested)
                return;

            _filterOptions = await GarmentDb.GetFilterOptionsAsync(ActiveUserId, request);
            if (cts.IsCancellationRequested)
                return;

            // Drop selections that no longer exist after dependent filtering updates.
            PruneSelection(_selectedCategories, _filterOptions.Categories);
            PruneSelection(_selectedSubcategories, _filterOptions.Subcategories);
            PruneSelection(_selectedColors, _filterOptions.Colors);
            PruneSelection(_selectedSeasons, _filterOptions.Seasons);
            PruneSelection(_selectedMaterials, _filterOptions.Materials);
            PruneSelection(_selectedBrands, _filterOptions.Brands);
            PruneSelection(_selectedFits, _filterOptions.Fits);
            PruneSelection(_selectedPatterns, _filterOptions.Patterns);
            PruneSelection(_selectedTags, _filterOptions.Tags);

            if (!ShouldShowClosetFilters)
                CloseClosetFilterDrawer();
        }
        catch (TaskCanceledException)
        {
            // Debounce cancellation.
        }
        finally
        {
            if (ReferenceEquals(_filterCts, cts))
            {
                _filterCts = null;
                _filtersBusy = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    // הסבר: פונקציה זו היא חלק מזרימת הקובץ: קלט -> עיבוד -> תוצאה/עדכון מצב.
    private static void PruneSelection(HashSet<string> selected, IReadOnlyCollection<string>? available)
    {
        if (selected.Count == 0 || available == null || available.Count == 0)
            return;

        var availableSet = new HashSet<string>(available, StringComparer.OrdinalIgnoreCase);
        selected.RemoveWhere(x => !availableSet.Contains(x));
    }

