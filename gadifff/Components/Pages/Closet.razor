        _selectedSeasons.Count > 0 ||
        _selectedMaterials.Count > 0 ||
        _selectedBrands.Count > 0 ||
        _selectedFits.Count > 0 ||
        _selectedPatterns.Count > 0 ||
        _selectedTags.Count > 0;

