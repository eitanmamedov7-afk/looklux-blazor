        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_currentUser == null || file == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        Log($"upload-start user={ActiveUserId} file={file.Name} size={file.Size}");

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (file.Size > 6 * 1024 * 1024)
        {
            _isErr = true;
            _msg = "Image too large (max 6MB).";
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;
        }

        _loading = true;
        _loadingText = "Analyzing garmentÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¦";
        StateHasChanged();

        byte[]? bytes = null;

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // ייבוא ספריות שמספקות מחלקות, ממשקים ופעולות שהקובץ צריך כדי לעבוד.
            using (var ms = new MemoryStream())
            {
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                await file.OpenReadStream(maxAllowedSize: 6 * 1024 * 1024).CopyToAsync(ms);
                bytes = ms.ToArray();
            }

            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var sha = Sha256Hex(bytes);
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var featureJson = await FeatureSvc.ExtractFromImageAsync(
                bytes,
                file.Name ?? "upload.jpg",
                file.ContentType ?? "image/jpeg");
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var preview = (featureJson ?? string.Empty);
            Log($"gemini-response len={preview.Length} preview={preview.Substring(0, Math.Min(200, preview.Length))}");

            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var parsed = ParseFeatures(featureJson ?? "{}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (string.IsNullOrWhiteSpace(parsed.Type))
            {
                PrepareManualFallback(bytes, file, sha, featureJson, "AI could not detect the garment type.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var saved = await PersistGarmentAsync(
                parsed.Type,
                parsed.Color,
                parsed.ColorSecondary,
                parsed.Pattern,
                parsed.StyleCategory,
                parsed.Season,
                parsed.Occasion,
                parsed.FormalityLevel,
                parsed.StyleTags,
                parsed.Fit,
                parsed.Material,
                parsed.Sleeve,
                parsed.Length,
                parsed.Brand,
                featureJson,
                bytes,
                file.ContentType ?? "image/jpeg",
                file.Name ?? "",
                sha);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (saved) ClearPending();
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (InvalidOperationException ex)
        {
            _isErr = true;
            _msg = ex.Message;
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (bytes != null)
                PrepareManualFallback(bytes, file, Sha256Hex(bytes), null, ex.Message);
            Log("upload-error " + ex.Message);
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            _isErr = true;
            _msg = ex.Message;
            Log("upload-error " + ex.Message);
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _loading = false;
            _loadingText = string.Empty;
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await InvokeAsync(StateHasChanged);
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
