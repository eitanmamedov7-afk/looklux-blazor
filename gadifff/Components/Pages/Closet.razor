@* זרימת קובץ: רכיב זה מקבל קלט מהמשתמש/מהשירותים, מעדכן מצב פנימי, ומציג תוצאה ברורה במסך. *@
@page "/closet"
@rendermode InteractiveServer
@implements IDisposable

@using System.Security.Cryptography
@using System.Text.Json
@using System.Diagnostics
@using Models
@using DBL
@using gadifff.Services
@using Microsoft.AspNetCore.Components.Forms

@inject IAuthService Auth
@inject UserDB UserDb
@inject GarmentDB GarmentDb
@inject GarmentImageDB GarmentImageDb
@inject GarmentFeatureService FeatureSvc
@inject NavigationManager Nav

<PageTitle>My Closet</PageTitle>

@if (!_loaded)
{
    <p>Loading...</p>
}
else if (_currentUser is null)
{
    <div class="alert alert-warning">
        You must login to view your closet.
    </div>

    <button class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/login"))">
        Go to login
    </button>
}
else
{
    <div class="page-shell">
        <div class="section-header">
            <div>
                <div class="section-title">My Closet</div>
                <div class="section-subtitle">Stored garments, auto-tagged and ready for matches.</div>
            </div>
            <div class="action-group">
                <button class="btn btn-outline-primary" @onclick="() => OpenMatcher(new List<string>(), false)">
                    Open matcher
                </button>
                <button class="btn btn-outline-secondary" @onclick="OpenBestRecommendations">
                    Get Best Recommendations
                </button>
            </div>
        </div>

        @if (_isAdminActingOnAnotherUser)
        {
            <div class="alert alert-info d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
                <div>
                    Admin mode: managing <strong>@_activeUserDisplayName</strong>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-primary" @onclick="OpenActiveUserOutfits">
                        Open outfits
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ExitAdminActingMode">
                        Back to my closet
                    </button>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_recommendationNotice))
        {
            <div class="alert @(_recommendationNoticeIsError ? "alert-warning" : "alert-success")">
                @_recommendationNotice
            </div>
        }

        @if (!string.IsNullOrEmpty(_msg))
        {
            <div class="alert @( _isErr ? "alert-danger" : "alert-success")">
                @_msg
            </div>
        }

        @if (_allowManual)
        {
            <div class="card border-warning">
                <div class="card-body d-flex flex-column flex-md-row align-items-center gap-3">
                    <div class="fw-bold text-warning">Automatic detection unavailable</div>
                    <InputSelect class="form-select manual-type-select" @bind-Value="_manualType">
                        <option value="shirt">Shirt / top</option>
                        <option value="pants">Pants / jeans / shorts</option>
                        <option value="shoes">Shoes / sneakers / boots</option>
                    </InputSelect>
                    <button class="btn btn-warning" @onclick="SaveManualAsync">Save manually</button>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-body d-flex flex-column flex-md-row align-items-start gap-3">
                <div>
                    <h5 class="card-title mb-1">Upload garment</h5>
                    <div class="text-muted small">We’ll analyze the image to detect type, color, fit, and more.</div>
                </div>
                <div class="ms-md-auto">
                    <InputFile OnChange="OnFileChange" accept="image/*" class="form-control" />
                </div>
            </div>
        </div>

        @if (ShouldShowClosetFilters)
        {
            <div class="filter-toolbar">
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="OpenClosetFilterDrawer">
                    Filters (@ClosetFilterSelectionCount)
                </button>
                @if (_filtersBusy)
                {
                    <span class="text-muted small">Updating...</span>
                }
                <div class="text-muted small filter-toolbar-summary">@ClosetActiveFilterSummary</div>
            </div>
        }

        @if (_items.Count == 0)
        {
            <div class="empty-state">No garments yet. Upload one to see it here.</div>
        }
        else if (_filteredItems.Count == 0)
        {
            <div class="empty-state">No garments match the current filters.</div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-3 g-3">
                @foreach (var g in FilteredItems)
                {
                    <div class="col">
                        <div class="card h-100">
                            <img class="card-img-top garment-card-image"
                                 src="@($"/media/garments/by-garment/{g.GarmentId}")"
                                 loading="lazy"
                                 decoding="async"
                                 @onclick="() => OpenGarmentPreview(g.GarmentId)"
                                 onerror="this.style.display='none';" />

                            <div class="card-body">
                                <h6 class="card-title">@g.Type</h6>
                                <div class="text-muted">@g.Color</div>
                                <div class="text-muted">@g.Brand</div>
                                @if (!string.IsNullOrWhiteSpace(g.FeatureJson))
                                {
                                    <div class="mt-2">
                                        @foreach (var tag in RenderTags(g.FeatureJson))
                                        {
                                            <span class="badge bg-light text-dark border me-1">@tag</span>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="card-footer d-flex justify-content-between">
                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => OpenMatcher(new List<string>{ g.GarmentId }, true)">
                                    Find matches
                                </button>
                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => ConfirmDeleteGarmentDialog(g.GarmentId)">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (ShouldShowClosetFilters)
        {
            <div class="filter-drawer-shell @(_showClosetFilterDrawer ? "is-open" : string.Empty)">
                <button type="button"
                        class="filter-drawer-backdrop"
                        @onclick="CloseClosetFilterDrawer"
                        aria-label="Close closet filters">
                </button>

                <aside class="filter-drawer-panel"
                       role="dialog"
                       aria-label="Closet filters"
                       aria-modal="true">
                    @if (_activeClosetFilterGroup == ClosetFilterGroup.None)
                    {
                        <div class="filter-drawer-header filter-drawer-header--summary">
                            <div>
                                <div class="fw-bold">Closet filters</div>
                                <div class="text-muted small">@ClosetActiveFilterSummary</div>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="CloseClosetFilterDrawer">
                                Close
                            </button>
                        </div>

                        <div class="filter-drawer-groups">
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Category)">
                                <span>Category</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Category)</span>
                            </button>
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Subcategory)">
                                <span>Subcategory</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Subcategory)</span>
                            </button>
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Color)">
                                <span>Color</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Color)</span>
                            </button>
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Season)">
                                <span>Season</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Season)</span>
                            </button>
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Material)">
                                <span>Material</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Material)</span>
                            </button>
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Brand)">
                                <span>Brand</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Brand)</span>
                            </button>
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Fit)">
                                <span>Fit</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Fit)</span>
                            </button>
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Pattern)">
                                <span>Pattern</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Pattern)</span>
                            </button>
                            <button type="button" class="filter-group-item" @onclick="() => OpenClosetFilterGroup(ClosetFilterGroup.Tags)">
                                <span>Tags</span>
                                <span class="filter-group-meta">@GetClosetGroupSummary(ClosetFilterGroup.Tags)</span>
                            </button>
                        </div>

                        <div class="filter-drawer-footer">
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="ApplyShoesOnlyFilter"
                                    disabled="@(_selectedCategories.SetEquals(new[] { "shoes" }))">
                                Only shoes
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="ClearAllClosetFilters"
                                    disabled="@(!HasActiveClosetFilters)">
                                Clear all
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="filter-drawer-header">
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="BackToClosetFilterGroups">
                                Back
                            </button>
                            <div class="fw-bold">@GetClosetFilterGroupTitle(_activeClosetFilterGroup)</div>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="CloseClosetFilterDrawer">
                                Close
                            </button>
                        </div>

                        <div class="filter-drawer-controls">
                            <input class="form-control form-control-sm"
                                   placeholder="Search options..."
                                   @bind="_closetFilterSearch"
                                   @bind:event="oninput" />
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="ClearActiveClosetGroupAsync">
                                Clear
                            </button>
                        </div>

                        <div class="filter-drawer-options">
                            @{
                                var options = GetVisibleClosetOptions(_activeClosetFilterGroup).ToList();
                            }
                            @if (options.Count == 0)
                            {
                                <div class="text-muted small">No options</div>
                            }
                            else
                            {
                                @foreach (var option in options)
                                {
                                    var optionValue = option;
                                    <label class="form-check filter-drawer-option">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               checked="@IsClosetOptionSelected(_activeClosetFilterGroup, optionValue)"
                                               @onchange="e => ToggleClosetGroupOption(_activeClosetFilterGroup, optionValue, e)" />
                                        <span class="form-check-label">@optionValue</span>
                                    </label>
                                }
                            }
                        </div>
                    }
                </aside>
            </div>
        }
    </div>
}

@if (_showMatcher && _currentUser != null)
{
    <SlotMachineMatch UserId="@ActiveUserId"
                      Garments="@(_matcherGarments.Count > 0 ? _matcherGarments : _items)"
                      UserRequest="_matcherRequest"
                      SeedGarmentIds="_seedIds"
                      AutoStart="_autoStart"
                      RequireSeedSelection="_requireSeedSelection"
                      OnClose="CloseMatcher"
                      OnMatchComplete="ReloadAfterMatch" />
}

@if (!string.IsNullOrWhiteSpace(_previewImageUrl))
{
    <div class="slot-overlay">
        <div class="slot-panel preview-panel">
            <div class="d-flex justify-content-end mb-2 preview-header">
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseGarmentPreview">Close</button>
            </div>
            <img src="@_previewImageUrl"
                 class="preview-image"
                 onerror="this.style.display='none';" />
        </div>
    </div>
}

@if (_showBestRecommendationWindow)
{
    <div class="slot-overlay best-reco-overlay">
        <div class="slot-panel best-reco-modal">
            <div class="d-flex justify-content-between align-items-center mb-2 best-reco-header">
                <div class="fw-bold best-reco-title">Best Recommendation Filters</div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseBestRecommendationWindow">Close</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_bestRecommendationWindowError))
            {
                <div class="alert alert-warning">@_bestRecommendationWindowError</div>
            }

            <div class="best-reco-group">
                <div class="fw-bold mb-2 best-reco-group-title">Outfit request (optional)</div>
                <textarea class="form-control"
                          rows="4"
                          placeholder="Example: black sporty outfit for winter evenings"
                          @bind="_bestRecommendationRequest"></textarea>
                <div class="text-muted small best-reco-empty">
                    Leave empty to run default best recommendations from your wardrobe.
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3 best-reco-actions">
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseBestRecommendationWindow">Cancel</button>
                <button class="btn btn-sm btn-primary" @onclick="ApplyBestRecommendationFiltersAndRunAsync">@ClosetBestRecommendationActionLabel</button>
            </div>
        </div>
    </div>
}

@if (_showDeleteGarmentDialog)
{
    <div class="slot-overlay">
        <div class="slot-panel confirm-modal">
            <div class="fw-bold">Delete garment</div>
            @if (string.IsNullOrWhiteSpace(_deleteGarmentDialogMessage))
            {
                <div class="text-muted">This action cannot be undone.</div>
            }
            else
            {
                <div class="alert @(_deleteGarmentDialogIsError ? "alert-warning" : "alert-success") mb-0">
                    @_deleteGarmentDialogMessage
                </div>
            }
            <div class="d-flex justify-content-end gap-2">
                @if (_deleteGarmentDialogCompleted)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseDeleteGarmentDialog">Close</button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="CloseDeleteGarmentDialog"
                            disabled="@_deleteGarmentDialogBusy">
                        Cancel
                    </button>
                    <button class="btn btn-sm btn-danger"
                            @onclick="DeleteGarmentConfirmedAsync"
                            disabled="@_deleteGarmentDialogBusy">
                        @(_deleteGarmentDialogBusy ? "Deleting..." : "Delete")
                    </button>
                }
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="slot-overlay blocking-loading-overlay">
        <div class="slot-panel text-center blocking-loading-panel">
            <div class="spinner-border text-light blocking-loading-spinner" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-3 fw-bold blocking-loading-title">Analyzing garment…</div>
            <div class="text-muted small blocking-loading-subtitle">@_loadingText</div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "asUserId")]
    public string? AsUserId { get; set; }

    private bool _loaded;
    private User? _currentUser;
    private string _activeUserId = string.Empty;
    private string _activeUserDisplayName = string.Empty;
    private bool _isAdminActingOnAnotherUser;
    private string _resolvedAsUserId = string.Empty;

    private List<Garment> _items = new();
    private List<Garment> _filteredItems = new();

    private GarmentFilterOptions _filterOptions = new();
    private readonly HashSet<string> _selectedCategories = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedSubcategories = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedColors = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedSeasons = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedMaterials = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedBrands = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedFits = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedPatterns = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedTags = new(StringComparer.OrdinalIgnoreCase);
    private CancellationTokenSource? _filterCts;
    private bool _filtersBusy;
    private bool _showClosetFilterDrawer;
    private ClosetFilterGroup _activeClosetFilterGroup = ClosetFilterGroup.None;
    private string _closetFilterSearch = string.Empty;

    private byte[]? _pendingBytes;
    private string? _pendingContentType;
    private string? _pendingFileName;
    private string? _pendingHash;
    private string _manualType = "shirt";
    private bool _allowManual;

    private string _msg = "";
    private bool _isErr;

    private bool _showMatcher;
    private List<string> _seedIds = new();
    private bool _autoStart;
    private bool _requireSeedSelection = true;
    private List<Garment> _matcherGarments = new();
    private string _matcherRequest = string.Empty;
    private string? _previewImageUrl;
    private string _recommendationNotice = string.Empty;
    private bool _recommendationNoticeIsError;
    private bool _showBestRecommendationWindow;
    private string _bestRecommendationWindowError = string.Empty;
    private string _bestRecommendationRequest = string.Empty;
    private bool _showDeleteGarmentDialog;
    private string? _deleteGarmentId;
    private string _deleteGarmentDialogMessage = string.Empty;
    private bool _deleteGarmentDialogIsError;
    private bool _deleteGarmentDialogBusy;
    private bool _deleteGarmentDialogCompleted;
    private string ActiveUserId => string.IsNullOrWhiteSpace(_activeUserId)
        ? (_currentUser?.UserId ?? string.Empty)
        : _activeUserId;

    // הסבר: פונקציית אירוע. היא מופעלת מתגובה לפעולה בממשק המשתמש ומעדכנת מצב/תצוגה.
    protected override Task OnInitializedAsync()
    {
        _loaded = false;
        return Task.CompletedTask;
    }

    // הסבר: פונקציית אירוע. היא מופעלת מתגובה לפעולה בממשק המשתמש ומעדכנת מצב/תצוגה.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _currentUser = await Auth.CurrentUserAsync();

        if (_currentUser != null)
        {
            await ResolveActiveUserContextAsync();
            await ReloadClosetDataAsync();
        }

        _loaded = true;
        await InvokeAsync(StateHasChanged);
    }

    // הסבר: פונקציית אירוע. היא מופעלת מתגובה לפעולה בממשק המשתמש ומעדכנת מצב/תצוגה.
    protected override async Task OnParametersSetAsync()
    {
        if (_currentUser == null || !_loaded)
            return;

        var normalized = NormalizeAsUserId(AsUserId);
        if (string.Equals(normalized, _resolvedAsUserId, StringComparison.OrdinalIgnoreCase))
            return;

        await ResolveActiveUserContextAsync();
        await ReloadClosetDataAsync();
    }



    // הסבר: פונקציית אירוע. היא מופעלת מתגובה לפעולה בממשק המשתמש ומעדכנת מצב/תצוגה.
    private async void OnFileChange(InputFileChangeEventArgs e)
    {
        await UploadFromFileAsync(e.File);
    }

    // הסבר: פונקציה זו היא חלק מזרימת הקובץ: קלט -> עיבוד -> תוצאה/עדכון מצב.
    private async Task UploadFromFileAsync(IBrowserFile? file)
    {
        ClearPending();
        _msg = "";
        _isErr = false;

        if (_currentUser == null || file == null)
            return;

        Log($"upload-start user={ActiveUserId} file={file.Name} size={file.Size}");

        if (file.Size > 6 * 1024 * 1024)
        {
            _isErr = true;
            _msg = "Image too large (max 6MB).";
            return;
        }

        _loading = true;
        _loadingText = "Analyzing garment…";
        StateHasChanged();

        byte[]? bytes = null;

        try
        {
            using (var ms = new MemoryStream())
            {
                await file.OpenReadStream(maxAllowedSize: 6 * 1024 * 1024).CopyToAsync(ms);
                bytes = ms.ToArray();
            }

            var sha = Sha256Hex(bytes);
            var featureJson = await FeatureSvc.ExtractFromImageAsync(
                bytes,
                file.Name ?? "upload.jpg",
                file.ContentType ?? "image/jpeg");
            var preview = (featureJson ?? string.Empty);
            Log($"gemini-response len={preview.Length} preview={preview.Substring(0, Math.Min(200, preview.Length))}");

            var parsed = ParseFeatures(featureJson ?? "{}");
            if (string.IsNullOrWhiteSpace(parsed.Type))
            {
                PrepareManualFallback(bytes, file, sha, featureJson, "AI could not detect the garment type.");
                return;
            }

            var saved = await PersistGarmentAsync(
                parsed.Type,
                parsed.Color,
                parsed.ColorSecondary,
                parsed.Pattern,
                parsed.StyleCategory,
                parsed.Season,
                parsed.Occasion,
                parsed.FormalityLevel,
                parsed.StyleTags,
                parsed.Fit,
                parsed.Material,
                parsed.Sleeve,
                parsed.Length,
                parsed.Brand,
                featureJson,
                bytes,
                file.ContentType ?? "image/jpeg",
                file.Name ?? "",
                sha);
            if (saved) ClearPending();
        }
        catch (InvalidOperationException ex)
        {
            _isErr = true;
            _msg = ex.Message;
            if (bytes != null)
                PrepareManualFallback(bytes, file, Sha256Hex(bytes), null, ex.Message);
            Log("upload-error " + ex.Message);
        }
        catch (Exception ex)
        {
            _isErr = true;
            _msg = ex.Message;
            Log("upload-error " + ex.Message);
        }
        finally
        {
            _loading = false;
            _loadingText = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    // הסבר: פונקציה זו היא חלק מזרימת הקובץ: קלט -> עיבוד -> תוצאה/עדכון מצב.
    private void ConfirmDeleteGarmentDialog(string garmentId)
    {
        if (string.IsNullOrWhiteSpace(garmentId))
            return;

        _deleteGarmentId = garmentId;
        _deleteGarmentDialogMessage = string.Empty;
        _deleteGarmentDialogIsError = false;
        _deleteGarmentDialogBusy = false;
        _deleteGarmentDialogCompleted = false;
        _showDeleteGarmentDialog = true;
    }

    // הסבר: פונקציית פתיחה/סגירה. שולטת על חלון/דיאלוג/פאנל כדי לנהל את חוויית המשתמש.
    private void CloseDeleteGarmentDialog()
    {
        _showDeleteGarmentDialog = false;
        _deleteGarmentId = null;
        _deleteGarmentDialogMessage = string.Empty;
        _deleteGarmentDialogIsError = false;
        _deleteGarmentDialogBusy = false;
        _deleteGarmentDialogCompleted = false;
    }

    // הסבר: פונקציית מחיקה. מסירה נתון קיים ומחזירה תוצאה כדי לאשר שהפעולה הושלמה.
    private async Task DeleteGarmentConfirmedAsync()
    {
        if (_currentUser == null || string.IsNullOrWhiteSpace(_deleteGarmentId) || _deleteGarmentDialogBusy)
            return;

        _deleteGarmentDialogBusy = true;
        _deleteGarmentDialogMessage = string.Empty;
        _deleteGarmentDialogIsError = false;
        _deleteGarmentDialogCompleted = false;

        try
        {
            var deleted = await GarmentDb.DeleteGarmentAsync(_deleteGarmentId);
            if (deleted <= 0)
            {
                _deleteGarmentDialogIsError = true;
                _deleteGarmentDialogMessage = "Could not delete this garment.";
                return;
            }

            await ReloadClosetDataAsync();
            _deleteGarmentDialogMessage = "Garment deleted.";
            _deleteGarmentDialogCompleted = true;
        }
        catch (Exception ex)
        {
            _deleteGarmentDialogIsError = true;
            _deleteGarmentDialogMessage = $"Delete failed: {ex.Message}";
        }
        finally
        {
