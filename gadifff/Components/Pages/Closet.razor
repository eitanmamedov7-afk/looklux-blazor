        _items.Count > 1 || HasActiveClosetFilters;

    private int ClosetFilterSelectionCount =>
        _selectedCategories.Count +
        _selectedSubcategories.Count +
        _selectedColors.Count +
        _selectedSeasons.Count +
        _selectedMaterials.Count +
        _selectedBrands.Count +
        _selectedFits.Count +
        _selectedPatterns.Count +
        _selectedTags.Count;

    private string ClosetActiveFilterSummary
    {
        get
        {
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (!HasActiveClosetFilters)
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return "All items";

            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var chunks = new List<string>();
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedCategories.Count > 0) chunks.Add($"Category: {string.Join(", ", _selectedCategories)}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedSubcategories.Count > 0) chunks.Add($"Subcategory: {string.Join(", ", _selectedSubcategories)}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedColors.Count > 0) chunks.Add($"Color: {string.Join(", ", _selectedColors)}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedSeasons.Count > 0) chunks.Add($"Season: {string.Join(", ", _selectedSeasons)}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedMaterials.Count > 0) chunks.Add($"Material: {string.Join(", ", _selectedMaterials)}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedBrands.Count > 0) chunks.Add($"Brand: {string.Join(", ", _selectedBrands)}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedFits.Count > 0) chunks.Add($"Fit: {string.Join(", ", _selectedFits)}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedPatterns.Count > 0) chunks.Add($"Pattern: {string.Join(", ", _selectedPatterns)}");
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedTags.Count > 0) chunks.Add($"Tags: {string.Join(", ", _selectedTags)}");
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return string.Join(" | ", chunks);
        }
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task ReloadClosetDataAsync()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_currentUser == null || string.IsNullOrWhiteSpace(ActiveUserId))
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        _items = await GarmentDb.GetByUserAsync(ActiveUserId);
        _matcherGarments = _items.ToList();
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await RefreshClosetFiltersAsync(false);
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private GarmentFilterRequest BuildGarmentFilterRequest() =>
        new()
        {
            Categories = _selectedCategories.Select(x => x.ToLowerInvariant()).ToList(),
            Subcategories = _selectedSubcategories.Select(x => x.ToLowerInvariant()).ToList(),
            Colors = _selectedColors.Select(x => x.ToLowerInvariant()).ToList(),
            Seasons = _selectedSeasons.Select(x => x.ToLowerInvariant()).ToList(),
            Materials = _selectedMaterials.Select(x => x.ToLowerInvariant()).ToList(),
            Brands = _selectedBrands.Select(x => x.ToLowerInvariant()).ToList(),
            Fits = _selectedFits.Select(x => x.ToLowerInvariant()).ToList(),
            Patterns = _selectedPatterns.Select(x => x.ToLowerInvariant()).ToList(),
            Tags = _selectedTags.Select(x => x.ToLowerInvariant()).ToList()
        };

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task RefreshClosetFiltersAsync(bool debounce)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_currentUser == null || string.IsNullOrWhiteSpace(ActiveUserId))
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _filterCts?.Cancel();
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var cts = new CancellationTokenSource();
        _filterCts = cts;

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (debounce)
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                await Task.Delay(180, cts.Token);

            _filtersBusy = true;
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await InvokeAsync(StateHasChanged);

            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var request = BuildGarmentFilterRequest();
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            _filteredItems = await GarmentDb.GetFilteredByUserAsync(ActiveUserId, request);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (cts.IsCancellationRequested)
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            _filterOptions = await GarmentDb.GetFilterOptionsAsync(ActiveUserId, request);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (cts.IsCancellationRequested)
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;

            PruneSelection(_selectedCategories, _filterOptions.Categories);
            PruneSelection(_selectedSubcategories, _filterOptions.Subcategories);
            PruneSelection(_selectedColors, _filterOptions.Colors);
            PruneSelection(_selectedSeasons, _filterOptions.Seasons);
            PruneSelection(_selectedMaterials, _filterOptions.Materials);
            PruneSelection(_selectedBrands, _filterOptions.Brands);
            PruneSelection(_selectedFits, _filterOptions.Fits);
            PruneSelection(_selectedPatterns, _filterOptions.Patterns);
            PruneSelection(_selectedTags, _filterOptions.Tags);

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (!ShouldShowClosetFilters)
                CloseClosetFilterDrawer();
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (TaskCanceledException)
        {
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (ReferenceEquals(_filterCts, cts))
            {
                _filterCts = null;
                _filtersBusy = false;
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static void PruneSelection(HashSet<string> selected, IReadOnlyCollection<string>? available)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (selected.Count == 0 || available == null || available.Count == 0)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var availableSet = new HashSet<string>(available, StringComparer.OrdinalIgnoreCase);
        selected.RemoveWhere(x => !availableSet.Contains(x));
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static HashSet<string> NormalizeSelected(HashSet<string> values) =>
        new(values
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x.Trim().ToLowerInvariant()),
            StringComparer.OrdinalIgnoreCase);

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task OnCategoriesChanged(HashSet<string> values)
    {
        _selectedCategories.Clear();
        _selectedCategories.UnionWith(NormalizeSelected(values));
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await RefreshClosetFiltersAsync(true);
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
