    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void OpenClosetFilterDrawer()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (!ShouldShowClosetFilters)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _showClosetFilterDrawer = true;
        _activeClosetFilterGroup = ClosetFilterGroup.None;
        _closetFilterSearch = string.Empty;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void CloseClosetFilterDrawer()
    {
        _showClosetFilterDrawer = false;
        _activeClosetFilterGroup = ClosetFilterGroup.None;
        _closetFilterSearch = string.Empty;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void OpenClosetFilterGroup(ClosetFilterGroup group)
    {
        _activeClosetFilterGroup = group;
        _closetFilterSearch = string.Empty;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void BackToClosetFilterGroups()
    {
        _activeClosetFilterGroup = ClosetFilterGroup.None;
        _closetFilterSearch = string.Empty;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private string GetClosetFilterGroupTitle(ClosetFilterGroup group) =>
        // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
        group switch
        {
            ClosetFilterGroup.Category => "Category",
            ClosetFilterGroup.Subcategory => "Subcategory",
            ClosetFilterGroup.Color => "Color",
            ClosetFilterGroup.Season => "Season",
            ClosetFilterGroup.Material => "Material",
            ClosetFilterGroup.Brand => "Brand",
            ClosetFilterGroup.Fit => "Fit",
            ClosetFilterGroup.Pattern => "Pattern",
            ClosetFilterGroup.Tags => "Tags",
            _ => "Filters"
        };

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private string GetClosetGroupSummary(ClosetFilterGroup group)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var count = GetClosetGroupSelectionCount(group);
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return count == 0 ? "All" : $"{count} selected";
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private int GetClosetGroupSelectionCount(ClosetFilterGroup group) =>
        GetClosetSelectionSet(group)?.Count ?? 0;

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private HashSet<string>? GetClosetSelectionSet(ClosetFilterGroup group) =>
        // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
        group switch
        {
            ClosetFilterGroup.Category => _selectedCategories,
            ClosetFilterGroup.Subcategory => _selectedSubcategories,
            ClosetFilterGroup.Color => _selectedColors,
            ClosetFilterGroup.Season => _selectedSeasons,
            ClosetFilterGroup.Material => _selectedMaterials,
            ClosetFilterGroup.Brand => _selectedBrands,
            ClosetFilterGroup.Fit => _selectedFits,
            ClosetFilterGroup.Pattern => _selectedPatterns,
            ClosetFilterGroup.Tags => _selectedTags,
            _ => null
        };

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private IReadOnlyCollection<string> GetClosetGroupOptions(ClosetFilterGroup group) =>
        // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
        group switch
        {
            ClosetFilterGroup.Category => _filterOptions.Categories,
            ClosetFilterGroup.Subcategory => _filterOptions.Subcategories,
            ClosetFilterGroup.Color => _filterOptions.Colors,
            ClosetFilterGroup.Season => _filterOptions.Seasons,
            ClosetFilterGroup.Material => _filterOptions.Materials,
            ClosetFilterGroup.Brand => _filterOptions.Brands,
            ClosetFilterGroup.Fit => _filterOptions.Fits,
            ClosetFilterGroup.Pattern => _filterOptions.Patterns,
            ClosetFilterGroup.Tags => _filterOptions.Tags,
            _ => Array.Empty<string>()
        };

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private IEnumerable<string> GetVisibleClosetOptions(ClosetFilterGroup group)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var options = GetClosetGroupOptions(group);
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (string.IsNullOrWhiteSpace(_closetFilterSearch))
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return options;

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var search = _closetFilterSearch.Trim();
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return options.Where(x => x.Contains(search, StringComparison.OrdinalIgnoreCase));
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private bool IsClosetOptionSelected(ClosetFilterGroup group, string option)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var set = GetClosetSelectionSet(group);
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return set != null && set.Contains(option);
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static bool IsChecked(ChangeEventArgs args) =>
        args.Value is bool b
            ? b
            : bool.TryParse(args.Value?.ToString(), out var parsed) && parsed;

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task ToggleClosetGroupOption(ClosetFilterGroup group, string option, ChangeEventArgs args)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var set = GetClosetSelectionSet(group);
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (set == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var normalized = (option ?? string.Empty).Trim().ToLowerInvariant();
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (string.IsNullOrWhiteSpace(normalized))
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsChecked(args))
            set.Add(normalized);
        // מסלול חלופי שפועל כאשר התנאי הקודם לא התקיים.
        else
            set.Remove(normalized);

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await RefreshClosetFiltersAsync(true);
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task ClearActiveClosetGroupAsync()
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var set = GetClosetSelectionSet(_activeClosetFilterGroup);
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (set == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        set.Clear();
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await RefreshClosetFiltersAsync(true);
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task ApplyShoesOnlyFilter()
    {
        _selectedCategories.Clear();
        _selectedCategories.Add("shoes");
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await RefreshClosetFiltersAsync(true);
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private (string Type, string? Color, string? ColorSecondary, string? Pattern, string? StyleCategory, string? Season, string? Occasion, int? FormalityLevel, string? StyleTags, string? Fit, string? Material, string? Sleeve, string? Length, string? Brand) ParseFeatures(string json)
    {
        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var doc = JsonDocument.Parse(json ?? "{}");
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var root = doc.RootElement;
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            string type = root.TryGetProperty("type", out var t) ? t.GetString() ?? "" : "";
            string? color = root.TryGetProperty("color", out var c) ? c.GetString() : null;
            string? colorSecondary = root.TryGetProperty("color_secondary", out var c2) ? c2.GetString() : null;
            string? pattern = root.TryGetProperty("pattern", out var p) ? p.GetString() : null;
            string? styleCategory = root.TryGetProperty("style_category", out var sc) ? sc.GetString() : null;
            string? season = root.TryGetProperty("season", out var se) ? se.GetString() : null;
            string? occasion = root.TryGetProperty("occasion", out var oc) ? oc.GetString() : null;
            string? fit = root.TryGetProperty("fit", out var f) ? f.GetString() : null;
            string? material = root.TryGetProperty("material", out var m) ? m.GetString() : null;
            string? sleeve = root.TryGetProperty("sleeve", out var s) ? s.GetString() : null;
            string? length = root.TryGetProperty("length", out var l) ? l.GetString() : null;
            string? brand = root.TryGetProperty("brand", out var b) ? b.GetString() : null;
            int? formalityLevel = null;
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (root.TryGetProperty("formality_level", out var fl))
            {
                // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
                if (fl.ValueKind == JsonValueKind.Number && fl.TryGetInt32(out var num))
                    formalityLevel = num;
                // מסלול חלופי שפועל כאשר התנאי הקודם לא התקיים.
                else if (fl.ValueKind == JsonValueKind.String && int.TryParse(fl.GetString(), out var parsed))
                    formalityLevel = parsed;
            }

            string? styleTags = null;
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (root.TryGetProperty("style_tags", out var tags) && tags.ValueKind == JsonValueKind.Array)
            {
                // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
                var values = tags.EnumerateArray()
                    .Select(x => x.GetString())
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .Select(x => x!.Trim())
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();
                // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
                if (values.Count > 0)
                    styleTags = JsonSerializer.Serialize(values);
            }

            type = NormalizeType(type, json ?? string.Empty);
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return (type, color, colorSecondary, pattern, styleCategory, season, occasion, formalityLevel, styleTags, fit, material, sleeve, length, brand);
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch
        {
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return ("", null, null, null, null, null, null, null, null, null, null, null, null, null);
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static string NormalizeType(string? raw, string fullJson)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var t = (raw ?? string.Empty).Trim().ToLowerInvariant();
        string matchFrom(string source)
        {
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("shirt")) return "shirt";
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("t-shirt")) return "shirt";
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("tee")) return "shirt";
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("pant")) return "pants";
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("trouser")) return "pants";
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("jean")) return "pants";
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("shoe")) return "shoes";
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("sneaker")) return "shoes";
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (source.Contains("boot")) return "shoes";
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return "";
        }

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var first = matchFrom(t);
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (!string.IsNullOrEmpty(first)) return first;

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var second = matchFrom((fullJson ?? string.Empty).ToLowerInvariant());
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (!string.IsNullOrEmpty(second)) return second;

        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return "";
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static void Log(string message)
    {
        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try { Debug.WriteLine("[Closet] " + message); } catch { }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static string NormalizeAsUserId(string? asUserId) =>
        (asUserId ?? string.Empty).Trim();

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task ResolveActiveUserContextAsync()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_currentUser == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _resolvedAsUserId = NormalizeAsUserId(AsUserId);
        _activeUserId = _currentUser.UserId;
        _activeUserDisplayName = string.IsNullOrWhiteSpace(_currentUser.FullName)
            ? (_currentUser.Email ?? "current user")
            : _currentUser.FullName;
        _isAdminActingOnAnotherUser = false;

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (string.IsNullOrWhiteSpace(_resolvedAsUserId) ||
            !string.Equals(_currentUser.Role, "admin", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(_resolvedAsUserId, _currentUser.UserId, StringComparison.OrdinalIgnoreCase))
        {
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;
        }

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        var targetUser = await UserDb.GetByIdAsync(_resolvedAsUserId);
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (targetUser == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _activeUserId = targetUser.UserId;
        _activeUserDisplayName = string.IsNullOrWhiteSpace(targetUser.FullName)
            ? (targetUser.Email ?? "selected user")
            : targetUser.FullName;
        _isAdminActingOnAnotherUser = true;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void OpenActiveUserOutfits()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_isAdminActingOnAnotherUser && !string.IsNullOrWhiteSpace(ActiveUserId))
        {
            Nav.NavigateTo($"/outfits?asUserId={Uri.EscapeDataString(ActiveUserId)}");
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;
        }

        Nav.NavigateTo("/outfits");
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void ExitAdminActingMode()
    {
        Nav.NavigateTo("/closet");
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    public void Dispose()
    {
        _filterCts?.Cancel();
        _filterCts?.Dispose();
    }

    // הגדרת מבנה מרכזי שמרכז נתונים או פעוליות עובר החלק הזה בפרויקט.
    private enum ClosetFilterGroup
    {
        None,
        Category,
        Subcategory,
        Color,
        Season,
        Material,
        Brand,
        Fit,
        Pattern,
        Tags
    }
}
