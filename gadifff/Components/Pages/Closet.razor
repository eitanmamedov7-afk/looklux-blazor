    // Function role:
    // Extracts compact badge text from stored feature JSON for closet cards.
    private IEnumerable<string> RenderTags(string featureJson)
    {
        var list = new List<string>();
        try
        {
            var doc = JsonDocument.Parse(featureJson);
            if (doc.RootElement.TryGetProperty("style_tags", out var tags) && tags.ValueKind == JsonValueKind.Array)
            {
                foreach (var t in tags.EnumerateArray())
                {
                    var v = t.GetString();
                    if (!string.IsNullOrWhiteSpace(v))
                        list.Add(v!);
                }
            }

            if (doc.RootElement.TryGetProperty("color", out var c) && c.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(c.GetString()))
                list.Add(c.GetString()!);
            if (doc.RootElement.TryGetProperty("style_category", out var style) && style.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(style.GetString()))
                list.Add(style.GetString()!);
            if (doc.RootElement.TryGetProperty("occasion", out var occasion) && occasion.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(occasion.GetString()))
                list.Add(occasion.GetString()!);
            if (doc.RootElement.TryGetProperty("fit", out var f) && f.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(f.GetString()))
                list.Add(f.GetString()!);
        }
        catch
        {
        }

        return list;
    }

