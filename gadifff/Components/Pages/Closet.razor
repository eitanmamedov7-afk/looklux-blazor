            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var deleted = await GarmentDb.DeleteGarmentAsync(_deleteGarmentId);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (deleted <= 0)
            {
                _deleteGarmentDialogIsError = true;
                _deleteGarmentDialogMessage = "Could not delete this garment.";
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await ReloadClosetDataAsync();
            _deleteGarmentDialogMessage = "Garment deleted.";
            _deleteGarmentDialogCompleted = true;
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            _deleteGarmentDialogIsError = true;
            _deleteGarmentDialogMessage = $"Delete failed: {ex.Message}";
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _deleteGarmentDialogBusy = false;
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await InvokeAsync(StateHasChanged);
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static string Sha256Hex(byte[] bytes)
    {
        // ייבוא ספריות שמספקות מחלקות, ממשקים ופעולות שהקובץ צריך כדי לעבוד.
        using var sha = SHA256.Create();
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var hash = sha.ComputeHash(bytes);
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return Convert.ToHexString(hash).ToLowerInvariant();
    }

    private async Task<bool> PersistGarmentAsync(
        string type,
        string? color,
        string? colorSecondary,
        string? pattern,
        string? styleCategory,
        string? season,
        string? occasion,
        int? formalityLevel,
        string? styleTags,
        string? fit,
        string? material,
        string? sleeve,
        string? length,
        string? brand,
        string? featureJson,
        byte[] imageBytes,
        string contentType,
        string fileName,
        string sha)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var garmentId = Guid.NewGuid().ToString();
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var imageId = Guid.NewGuid().ToString();

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var g = new Garment
        {
            GarmentId = garmentId,
            OwnerUserId = ActiveUserId,
            Type = type,
            Color = color,
            ColorSecondary = colorSecondary,
            Pattern = pattern,
            StyleCategory = styleCategory,
            Season = season,
            Occasion = occasion,
            FormalityLevel = formalityLevel,
            StyleTags = styleTags,
            Fit = fit,
            Material = material,
            Sleeve = sleeve,
            Length = length,
            Brand = brand,
            FeatureJson = featureJson,
            GarmentHash = sha,
            CreatedAt = DateTime.UtcNow
        };

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        var inserted = await GarmentDb.CreateAsync(g);
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (inserted <= 0)
        {
            Log("db-insert failed " + (GarmentDb.LastError ?? ""));
            throw new Exception(string.IsNullOrWhiteSpace(GarmentDb.LastError)
                ? "Failed to add garment."
                : $"Failed to add garment: {GarmentDb.LastError}");
        }
        // מסלול חלופי שפועל כאשר התנאי הקודם לא התקיים.
        else
        {
            Log($"db-insert ok garmentId={garmentId}");
        }

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        var imgOk = await GarmentImageDb.CreateAsync(
            imageId,
            garmentId,
            ActiveUserId,
            contentType,
            fileName ?? "",
            imageBytes,
            sha);

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (imgOk <= 0)
        {
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await GarmentDb.DeleteGarmentAsync(garmentId);
            Log("db-image failed, rolled back garment");
            throw new Exception("Failed to save image.");
        }
        // מסלול חלופי שפועל כאשר התנאי הקודם לא התקיים.
        else
        {
            Log($"db-image ok imageId={imageId}");
        }

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await ReloadClosetDataAsync();
        _msg = "Added!";
        _isErr = false;
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return true;
    }

    private bool _loading;
