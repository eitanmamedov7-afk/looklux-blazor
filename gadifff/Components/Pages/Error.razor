
@page "/Error"

@using System.Diagnostics


<PageTitle>Error</PageTitle>

@* Role in project:
   Generic Blazor error page for unhandled server-side UI errors.
   It helps debugging by showing the request id without exposing production exception details. *@
@* Layout:
   Shows a simple error message and the request id so the problem can be matched with server logs. *@
<div class="page-shell">
    <h1>Error</h1>
    <h2 class="text-muted">An error occurred while processing your request.</h2>


    @if (ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@RequestId</code>
        </p>
    }

    <h3>Development mode</h3>
    <p class="text-muted">
        Swapping to <strong>Development</strong> environment shows more detailed error information.
    </p>
    <p class="text-muted">
        <strong>Do not enable Development in production.</strong>
        It can expose sensitive exception details.
    </p>
</div>



@code{
    // Cascaded request context lets the page show a trace id for logs/debugging.
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    // Request id is copied from Activity/HttpContext so the error can be matched to server logs.
    private string? RequestId { get; set; }
    // Controls whether the request id block appears in the error page layout.
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    // Copies the current request trace id for display on the error page.
    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
