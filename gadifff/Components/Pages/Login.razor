@page "/login"
@rendermode InteractiveServer

@* SEARCH INDEX
   LOGIN, AUTH, VALIDATE, COOKIE, USER, FORM, NAVIGATION

   Topic: WEB LOGIN PAGE
   Purpose: Collects email/password and calls AuthService.LoginAsync.
   Search keywords: LOGIN AUTH VALIDATE COOKIE USER FORM NAVIGATION
   When to use it: Show this when explaining the browser login flow.
   Important notes: This page starts web auth; the MAUI login flow uses Program.cs API endpoints instead. *@

@using System.ComponentModel.DataAnnotations
@using gadifff.Services

@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Sign in</PageTitle>

@* Role in project:
   This is the entry page for user authentication.
   Success here unlocks the rest of the product flow (closet, filters, matcher, saved outfits). *@
@* Layout:
   Centered sign-in card with email/password inputs, submit button, register navigation, and forgot-password link.
   This is the first screen a signed-out web user uses before reaching closet/outfit pages. *@
<div class="page-shell">
    <div class="row justify-content-center mt-1">
        <div class="col-md-6 col-lg-5">
            <h3 class="mb-4">Sign in</h3>

            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @(_isError ? "alert-danger" : "alert-success")" role="alert">
                    @_message
                </div>
            }

            <EditForm Model="_model"
                      OnValidSubmit="HandleLoginAsync"
                      FormName="login">
                @* FLOW_LOGIN_WEB_01: User submits the Sign in form; next step is HandleLoginAsync in this file. *@
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="_model.Email" />
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText type="password" class="form-control" @bind-Value="_model.Password" />
                    <ValidationMessage For="@(() => _model.Password)" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Sign in</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="GoToRegister">Get Access</button>
                </div>

                <div class="mt-3">
                    <a href="/forgot-password">Forgot password?</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    // Form state used by the login layout above.
    // _message/_isError control the success/error alert shown above the form.
    private LoginModel _model = new();
    private string _message = string.Empty;
    private bool _isError;

    // Function role:
    // FLOW_LOGIN_WEB_02: HandleLoginAsync sends the form email/password to AuthService.LoginAsync.
    // This page is involved because the web login starts from this form; next step is AuthService validating credentials.
    // Sends credentials to AuthService (AuthService.LoginAsync).
    // On success: redirects to home where closet/filter/recommendation flows are available.
    // On failure: keeps user on this page with an explicit error.
    private async Task HandleLoginAsync()
    {
        _isError = false;
        _message = string.Empty;

        var ok = await AuthService.LoginAsync(_model.Email, _model.Password);
        if (!ok)
        {
            _isError = true;
            _message = "Invalid email or password.";
            return;
        }

        Nav.NavigateTo("/");
    }

    // Function role:
    // Routes users who do not have an account into the registration flow.
    private void GoToRegister()
    {
        Nav.NavigateTo("/register");
    }

    // Data role:
    // Request payload for this page only; mirrors the two fields needed by AuthService.LoginAsync.
    public class LoginModel
    {
        // VALIDATION_EMAIL: Blazor login requires a valid email address before AuthService receives the form.
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        // VALIDATION_PASSWORD: Blazor login requires a password value before AuthService receives the form.
        [Required]
        public string Password { get; set; } = string.Empty;
    }
}



