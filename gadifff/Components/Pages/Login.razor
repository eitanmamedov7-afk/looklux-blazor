@* זרימת קובץ: רכיב זה מקבל קלט מהמשתמש/מהשירותים, מעדכן מצב פנימי, ומציג תוצאה ברורה במסך. *@
@page "/login"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using gadifff.Services

@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Sign in</PageTitle>

<div class="page-shell">
    <div class="row justify-content-center mt-1">
        <div class="col-md-6 col-lg-5">
            <h3 class="mb-4">Sign in</h3>

            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @( _isError ? "alert-danger" : "alert-success")" role="alert">
                    @_message
                </div>
            }

            <!-- שים לב: EditForm אחד עם FormName, בלי <form> רגיל סביבו -->
            <EditForm Model="_model"
                      OnValidSubmit="HandleLoginAsync"
                      FormName="login">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="_model.Email" />
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText type="password" class="form-control" @bind-Value="_model.Password" />
                    <ValidationMessage For="@(() => _model.Password)" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        Sign in
                    </button>
                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="GoToRegister">
                        Get Access
                    </button>
                </div>

                <div class="mt-3">
                    <a href="/forgot-password">Forgot password?</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string _message = string.Empty;
    private bool _isError;

    // הסבר: פונקציית טיפול באירוע. מקבלת קלט מה־UI, מבצעת בדיקות, ואז מפעילה את הלוגיקה המתאימה.
    private async Task HandleLoginAsync()
    {
        _isError = false;
        _message = string.Empty;

        var ok = await AuthService.LoginAsync(_model.Email, _model.Password);
        if (!ok)
        {
            _isError = true;
            _message = "Invalid email or password.";
            return;
        }

        // אחרי התחברות מוצלחת – לעמוד הבית
        Nav.NavigateTo("/");
    }

    // הסבר: פונקציה זו היא חלק מזרימת הקובץ: קלט -> עיבוד -> תוצאה/עדכון מצב.
    private void GoToRegister()
    {
        Nav.NavigateTo("/register");
    }

    public class LoginModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}
