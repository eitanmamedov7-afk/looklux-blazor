@* מה הקובץ עושה: הקובץ מציג מסך או רכיב בלייזור ומחבר בין התצוגה שעל המסך לבין אזור הקוד. *@
@* למה הקובץ נדרש: הוא נדרש כדי שהמשתמש יוכל לבצע פעולה או לראות מידע כחלק מהאתר. *@
@* לאילו חלקים בפרויקט הוא מתחבר: הוא מתחבר לשירותים, למודלים, לניווט ולשכבת הדיבי דרך ההזרקות ואזור הקוד. *@
@* איפה ממשיכים לקרוא את הלוגיקה הקשורה: ממשיכים באזור הקוד שבתחתית הקובץ ובשירותים או במחלקות הדיבי שנקראים ממנו. *@

@*
*@







@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@page "/forgot-password"

@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@rendermode InteractiveServer


@* ייבוא מרחו שמות שמאפשר לדף להשתמש במודלם, שירותים או כלים נוספים. *@
@using System.ComponentModel.DataAnnotations

@* ייבוא מרחו שמות שמאפשר לדף להשתמש במודלם, שירותים או כלים נוספים. *@
@using gadifff.Services



@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@inject IAuthService AuthService


@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@inject NavigationManager Nav


@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
<PageTitle>Forgot Password</PageTitle>

<div class="page-shell">
    <div class="row justify-content-center mt-1">
        <div class="col-md-6 col-lg-5">
            <h3 class="mb-4">Forgot password</h3>


            @* בדיקת תנאי שקובעת איזה מסלול בקוד יפעל לפי המצב הנוכחי. *@
            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @( _isError ? "alert-danger" : "alert-success")" role="alert">
                    @_message
                </div>
            }


            @* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
            <EditForm Model="_model" OnValidSubmit="HandleSendAsync" FormName="forgot-password">

                @* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
                <DataAnnotationsValidator />

                @* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Email</label>

                    @* הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת. *@
                    <InputText class="form-control" @bind-Value="_model.Email" />

                    @* הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה. *@
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                        Send reset email
                    </button>


                    @* הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת. *@
                    <button type="button" class="btn btn-outline-secondary" @onclick="GoToLogin">
                        Back to sign in
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>



@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@code {
    private ForgotPasswordModel _model = new();
    private string _message = string.Empty;
    private bool _isError;
    private bool _isSubmitting;

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task HandleSendAsync()
    {
        _isSubmitting = true;
        _isError = false;
        _message = string.Empty;

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var status = await AuthService.SendPasswordResetEmailAsync(_model.Email, Nav.BaseUri);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (status == PasswordResetEmailStatus.EmailNotFound)
            {
                _isError = true;
                _message = "No account was found with this email.";
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (status == PasswordResetEmailStatus.SendFailed)
            {
                _isError = true;
                _message = "Could not send reset email. If your Resend domain is still pending and FromEmail is onboarding@resend.dev, Resend only allows sending to your own Resend account email.";
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (status == PasswordResetEmailStatus.InvalidRequest)
            {
                _isError = true;
                _message = "Invalid reset request. Please refresh the page and try again.";
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            _message = "A password reset link has been sent.";
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _isSubmitting = false;
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void GoToLogin()
    {
        Nav.NavigateTo("/login");
    }

    // הגדרת מבנה מרכזי שמרכז נתונים או פעוליות עובר החלק הזה בפרויקט.
    public class ForgotPasswordModel
    {
        [Required, EmailAddress]
        // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
        public string Email { get; set; } = string.Empty;
    }
}
