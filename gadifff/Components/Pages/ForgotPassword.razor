
@page "/forgot-password"

@* SEARCH INDEX
   PASSWORD, RESET, EMAIL, VALIDATE, AUTH, FORM

   Topic: FORGOT PASSWORD PAGE
   Purpose: Starts password recovery by sending a reset email through AuthService.
   Search keywords: PASSWORD RESET EMAIL VALIDATE AUTH FORM
   When to use it: Show this when explaining forgot-password in the web app.
   Important notes: Uses PasswordResetEmailStatus to choose the exact user-facing message. *@

@rendermode InteractiveServer


@using System.ComponentModel.DataAnnotations

@using gadifff.Services



@inject IAuthService AuthService


@inject NavigationManager Nav


<PageTitle>Forgot Password</PageTitle>

@* Role in project:
   Starts the password reset flow for web users.
   The same AuthService process is also exposed to the MAUI app through the mobile API. *@
@* Layout:
   Centered email form with a submit button and a back-to-sign-in button.
   The alert above the form shows whether the reset email was sent or why it failed. *@
<div class="page-shell">
    <div class="row justify-content-center mt-1">
        <div class="col-md-6 col-lg-5">
            <h3 class="mb-4">Forgot password</h3>


            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @( _isError ? "alert-danger" : "alert-success")" role="alert">
                    @_message
                </div>
            }


            <EditForm Model="_model" OnValidSubmit="HandleSendAsync" FormName="forgot-password">

                <DataAnnotationsValidator />

                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Email</label>

                    <InputText class="form-control" @bind-Value="_model.Email" />

                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="d-flex gap-2">
                    @* FLOW_PASSWORD_RESET_WEB_01: User clicks Send reset email on the web forgot-password form; next step is HandleSendAsync. *@
                    <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                        Send reset email
                    </button>


                    <button type="button" class="btn btn-outline-secondary" @onclick="GoToLogin">
                        Back to sign in
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>



@code {
    // Page state for email input, submit lock, and user-facing reset status.
    private ForgotPasswordModel _model = new();
    private string _message = string.Empty;
    private bool _isError;
    private bool _isSubmitting;

    // Function role:
    // Requests a reset token/email from AuthService and maps each status to a clear UI message.
    // FLOW_PASSWORD_RESET_WEB_02: HandleSendAsync sends the entered email and browser base URL to AuthService.SendPasswordResetEmailAsync.
    // This page is involved because the web forgot-password form starts the reset email process; next step is UserDB account lookup inside AuthService.
    private async Task HandleSendAsync()
    {
        _isSubmitting = true;
        _isError = false;
        _message = string.Empty;

        try
        {
            var status = await AuthService.SendPasswordResetEmailAsync(_model.Email, Nav.BaseUri);
            if (status == PasswordResetEmailStatus.EmailNotFound)
            {
                _isError = true;
                _message = "No account was found with this email.";
                return;
            }

            if (status == PasswordResetEmailStatus.SendFailed)
            {
                _isError = true;
                _message = "Could not send reset email. If your Resend domain is still pending and FromEmail is onboarding@resend.dev, Resend only allows sending to your own Resend account email.";
                return;
            }

            if (status == PasswordResetEmailStatus.InvalidRequest)
            {
                _isError = true;
                _message = "Invalid reset request. Please refresh the page and try again.";
                return;
            }

            _message = "A password reset link has been sent.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    // Function role:
    // Returns the user to the normal sign-in flow.
    private void GoToLogin()
    {
        Nav.NavigateTo("/login");
    }

    // Data role:
    // The only required input for starting password recovery.
    public class ForgotPasswordModel
    {
        // VALIDATION_EMAIL: forgot-password requires a valid email before AuthService creates a reset request.
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
