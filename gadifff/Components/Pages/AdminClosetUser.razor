@page "/admin/closet/{UserId}"
@rendermode InteractiveServer

@* SEARCH INDEX
   ADMIN, CUSTOMER, CLOSET, OUTFIT, GARMENT, VIEW, LIST, READONLY

   Topic: ADMIN CUSTOMER OVERVIEW PAGE
   Purpose: Shows one customer's garments and outfits to an admin in read-only mode.
   Search keywords: ADMIN CUSTOMER CLOSET OUTFIT GARMENT VIEW LIST READONLY
   When to use it: Show this when explaining how admin can inspect customer data without editing it.
   Important notes: Buttons jump to shared closet/outfit pages using asUserId query mode. *@

@using Models
@using DBL
@using gadifff.Services

@inject IAuthService Auth
@inject UserDB UserDb
@inject GarmentDB GarmentDb
@inject OutfitDB OutfitDb
@inject NavigationManager Nav

<PageTitle>Customer data</PageTitle>

@* Role in project:
   Admin detail page for one customer.
   It gives a read-only wardrobe/outfit overview before opening the full read-only views. *@
@* Layout:
   Customer detail page with summary cards, garment/outfit tabs, and links into the full closet/outfit pages.
   It is only available to admins. *@
@if (_notAllowed)
{
    <p class="text-danger">Access denied.</p>
}
else if (_loading)
{
    <p>Loading…</p>
}
else if (_targetUser is null)
{
    <p>User not found.</p>
}
else
{
    @* Layout:
       Header shows the selected customer and action buttons for full closet/outfit views or back navigation. *@
    <div class="page-shell">
        <div class="section-header">
            <div>
                <div class="section-title">Customer data</div>
                <div class="section-subtitle">Garments and saved outfits</div>
                <div class="text-muted mt-1">@_targetUser.FullName (@_targetUser.Email)</div>
            </div>
            <div class="action-group">
                <button class="btn btn-outline-primary"
                        @onclick="OpenInteractiveCloset">
                    Open Full Closet
                </button>
                <button class="btn btn-outline-primary"
                        @onclick="OpenInteractiveOutfits">
                    Open Full Outfits
                </button>
                <button class="btn btn-outline-secondary" @onclick="GoBack">Back</button>
            </div>
        </div>

        @* Layout:
           Summary cards show how much data this customer owns: garments, saved outfits, and role. *@
        <div class="row g-3 mb-3">
            <div class="col-12 col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small">Garments</div>
                        <div class="fs-4 fw-bold">@_garments.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small">Saved outfits</div>
                        <div class="fs-4 fw-bold">@_outfits.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small">Role</div>
                        <div class="fs-4 fw-bold">@_targetUser.Role</div>
                    </div>
                </div>
            </div>
        </div>

        @* Layout:
           Tab buttons switch this admin detail view between garment rows and outfit rows. *@
        <div class="btn-group mb-3" role="group" aria-label="Wardrobe view switch">
            <button class="btn btn-sm @(_activeTab == ClosetTab.Garments ? "btn-primary" : "btn-outline-secondary")"
                    @onclick="@(() => _activeTab = ClosetTab.Garments)">
                Garments
            </button>
            <button class="btn btn-sm @(_activeTab == ClosetTab.Outfits ? "btn-primary" : "btn-outline-secondary")"
                    @onclick="@(() => _activeTab = ClosetTab.Outfits)">
                Outfits
            </button>
        </div>

        @if (_activeTab == ClosetTab.Garments)
        {
            @* Layout:
               Garment table shows image preview, type/color/brand, and created date.
               Admins can view customer garments here but cannot delete them. *@
            <div class="card">
                <div class="card-body">
                    <div class="fw-bold mb-2">Garments</div>

                    @if (_garments.Count == 0)
                    {
                        <div class="text-muted">No garments yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Preview</th>
                                        <th>Type</th>
                                        <th>Color</th>
                                        <th>Brand</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in _garments)
                                    {
                                        <tr>
                                            <td>
                                                <img src="@($"/media/garments/by-garment/{g.GarmentId}")"
                                                     style="width:56px;height:56px;object-fit:cover;border-radius:8px;border:1px solid #d7dce7;"
                                                     onerror="this.style.display='none';" />
                                            </td>
                                            <td>@g.Type</td>
                                            <td>@g.Color</td>
                                            <td>@g.Brand</td>
                                            <td>@g.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            @* Layout:
               Outfit table shows score/style/pieces and created date.
               Admins can view customer outfits here but cannot delete them. *@
            <div class="card">
                <div class="card-body">
                    <div class="fw-bold mb-2">Outfits</div>

                    @if (_outfits.Count == 0)
                    {
                        <div class="text-muted">No outfits yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Score</th>
                                        <th>Style</th>
                                        <th>Pieces</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in _outfits)
                                    {
                                        <tr>
                                            <td>@o.Score</td>
                                            <td>@(string.IsNullOrWhiteSpace(o.StyleLabel) ? "n/a" : o.StyleLabel)</td>
                                            <td>@FormatOutfitPieces(o)</td>
                                            <td>@o.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    // Route parameter identifying the customer being reviewed by an admin.
    [Parameter] public string UserId { get; set; } = string.Empty;

    // Page access/loading and feedback state.
    private bool _loading = true;
    private bool _notAllowed;

    // Target customer's wardrobe data shown in the summary tables.
    private User? _targetUser;
    private List<Garment> _garments = new();
    private List<Outfit> _outfits = new();
    private Dictionary<string, Garment> _garmentById = new(StringComparer.OrdinalIgnoreCase);
    private ClosetTab _activeTab = ClosetTab.Garments;

    // Function role:
    // Confirms the current user is an admin, then loads the selected customer's data.
    protected override async Task OnInitializedAsync()
    {
        var current = await Auth.CurrentUserAsync();
        if (current == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        if (!string.Equals(current.Role, "admin", StringComparison.OrdinalIgnoreCase))
        {
            _notAllowed = true;
            _loading = false;
            return;
        }

        await LoadTargetDataAsync();
        _loading = false;
    }

    // Function role:
    // Loads the customer, garments, saved outfits, and garment lookup used to label outfit pieces.
    // FLOW_ADMIN_VIEW_CUSTOMER_WEB_02: LoadTargetDataAsync loads the selected customer's garments and outfits read-only.
    // This page is involved because the admin customer detail screen starts here; next step is GarmentDB/OutfitDB queries.
    private async Task LoadTargetDataAsync()
    {
        _targetUser = await UserDb.GetByIdAsync(UserId);
        if (_targetUser == null)
            return;

        _garments = await GarmentDb.GetByUserAsync(_targetUser.UserId);
        _garmentById = _garments
            .Where(x => !string.IsNullOrWhiteSpace(x.GarmentId))
            .GroupBy(x => x.GarmentId, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(x => x.Key, x => x.Last(), StringComparer.OrdinalIgnoreCase);

        _outfits = (await OutfitDb.GetByUserAsync(_targetUser.UserId, 1500))
            .OrderByDescending(x => x.CreatedAt)
            .ToList();
    }

    // Function role:
    // Builds the "Pieces" text shown in the admin outfit table.
    private string FormatOutfitPieces(Outfit outfit)
    {
        var parts = new List<string>();
        AddPiece(parts, outfit.ShirtGarmentId);
        AddPiece(parts, outfit.PantsGarmentId);
        AddPiece(parts, outfit.ShoesGarmentId);
        return string.Join(", ", parts);
    }

    // Adds one readable garment type to the outfit piece summary.
    private void AddPiece(List<string> parts, string? garmentId)
    {
        if (string.IsNullOrWhiteSpace(garmentId))
            return;

        if (_garmentById.TryGetValue(garmentId, out var garment) &&
            !string.IsNullOrWhiteSpace(garment.Type))
        {
            parts.Add(garment.Type);
            return;
        }

        parts.Add("piece");
    }

    // Returns to the main admin customer list.
    private void GoBack()
    {
        Nav.NavigateTo("/admin/closets");
    }

    // Function role:
    // Opens the full Closet page in admin read-only mode for this customer.
    // FLOW_ADMIN_VIEW_CUSTOMER_WEB_03A: Admin opens the shared Closet page with asUserId for read-only customer garments.
    // This page is involved because it links customer detail to the full closet view; next step is Closet.razor resolving asUserId.
    private void OpenInteractiveCloset()
    {
        if (_targetUser == null)
            return;

        Nav.NavigateTo($"/closet?asUserId={Uri.EscapeDataString(_targetUser.UserId)}");
    }

    // Function role:
    // Opens the full Outfits page in admin read-only mode for this customer.
    // FLOW_ADMIN_VIEW_CUSTOMER_WEB_04A: Admin opens the shared Outfits page with asUserId for read-only customer outfits.
    // This page is involved because it links customer detail to the full outfits view; next step is Outfits.razor resolving asUserId.
    private void OpenInteractiveOutfits()
    {
        if (_targetUser == null)
            return;

        Nav.NavigateTo($"/outfits?asUserId={Uri.EscapeDataString(_targetUser.UserId)}");
    }

    // UI tab choices for the customer detail card.
    private enum ClosetTab
    {
        Garments,
        Outfits
    }

}
