@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@code {
    private bool _loaded;
    private bool _mustLogin;
    private bool _notAllowed;
    private bool _busy;
    private bool _isError;
    private string _message = string.Empty;
    private User? _currentUser;
    private List<User> _users = new();
    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private readonly Dictionary<string, string> _originalUserSnapshot = new(StringComparer.OrdinalIgnoreCase);
    private bool _showDeleteUserDialog;
    private User? _pendingDeleteUser;

    private string _createFullName = string.Empty;
    private string _createEmail = string.Empty;
    private string _createPassword = string.Empty;
    private string _createRole = "customer";

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    protected override async Task OnInitializedAsync()
    {
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        _currentUser = await Auth.CurrentUserAsync();
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_currentUser == null)
        {
            _mustLogin = true;
            _loaded = true;
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;
        }

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (!string.Equals(_currentUser.Role, "admin", StringComparison.OrdinalIgnoreCase))
        {
            _notAllowed = true;
            _loaded = true;
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;
        }

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await ReloadUsersAsync();
        _loaded = true;
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task ReloadUsersAsync()
    {
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        _users = (await UserDb.GetAllAsync())
            .OrderByDescending(x => x.CreatedAt)
            .ThenBy(x => x.Email, StringComparer.OrdinalIgnoreCase)
            .ToList();

        _originalUserSnapshot.Clear();
        // לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים.
        foreach (var user in _users)
            _originalUserSnapshot[user.UserId] = BuildUserSnapshot(user);
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task CreateUserAsync()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_busy)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _busy = true;
        ClearMessage();

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var fullName = (_createFullName ?? string.Empty).Trim();
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var email = (_createEmail ?? string.Empty).Trim().ToLowerInvariant();
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var password = _createPassword ?? string.Empty;
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var role = NormalizeRole(_createRole);

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (string.IsNullOrWhiteSpace(fullName) ||
                string.IsNullOrWhiteSpace(email) ||
                string.IsNullOrWhiteSpace(password))
            {
                SetError("Full name, email, and password are required.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (password.Length < 6)
            {
                SetError("Password must be at least 6 characters.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var existing = await UserDb.GetByEmailAsync(email);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (existing.Any())
            {
                SetError("Email already exists.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var user = new User
            {
                UserId = Guid.NewGuid().ToString(),
                FullName = fullName,
                Email = email,
                Role = role,
                PasswordHash = BCryptNet.HashPassword(password),
                CreatedAt = DateTime.UtcNow
            };

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var created = await UserDb.CreateAsync(user);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (created <= 0)
            {
                SetError("Could not create account.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            _createFullName = string.Empty;
            _createEmail = string.Empty;
            _createPassword = string.Empty;
            _createRole = "customer";

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await ReloadUsersAsync();
            SetSuccess($"Created {role} account.");
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            SetError($"Create failed: {ex.Message}");
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _busy = false;
        }
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task SaveUserAsync(User user)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_busy)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _busy = true;
        ClearMessage();

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var email = (user.Email ?? string.Empty).Trim().ToLowerInvariant();
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var fullName = (user.FullName ?? string.Empty).Trim();
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var role = NormalizeRole(user.Role);
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var persistedUser = await UserDb.GetByIdAsync(user.UserId);

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (persistedUser == null)
            {
                SetError("User no longer exists.");
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                await ReloadUsersAsync();
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(fullName))
            {
                SetError("Email and full name are required.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var duplicate = await UserDb.GetByEmailAsync(email);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (duplicate.Any(x => !string.Equals(x.UserId, user.UserId, StringComparison.OrdinalIgnoreCase)))
            {
                SetError("Another account already uses that email.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (string.Equals(user.UserId, _currentUser?.UserId, StringComparison.OrdinalIgnoreCase) &&
                !string.Equals(role, "admin", StringComparison.OrdinalIgnoreCase))
            {
                SetError("You cannot remove your own admin role.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var persistedRole = NormalizeRole(persistedUser.Role);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (persistedRole == "admin" && role != "admin")
            {
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                var adminCount = await UserDb.CountByRoleAsync("admin");
                // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
                if (adminCount <= 1)
                {
                    SetError("Cannot remove the last admin account.");
                    // החזרת התוצאה אל הקוד שקרא לפעולה.
                    return;
                }
            }

            user.Email = email;
            user.FullName = fullName;
            user.Role = role;

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var updated = await UserDb.UpdateUserAsync(user);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (updated <= 0)
            {
                SetError("No changes were saved.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await ReloadUsersAsync();
            SetSuccess("User updated.");
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            SetError($"Save failed: {ex.Message}");
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _busy = false;
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void OpenDeleteUserDialog(User user)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_busy)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _pendingDeleteUser = user;
        _showDeleteUserDialog = true;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void CloseDeleteUserDialog()
    {
        _showDeleteUserDialog = false;
        _pendingDeleteUser = null;
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task DeleteUserConfirmedAsync()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_pendingDeleteUser == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await DeleteUserAsync(_pendingDeleteUser);
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (!_isError)
            CloseDeleteUserDialog();
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task DeleteUserAsync(User user)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_busy)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (string.Equals(user.UserId, _currentUser?.UserId, StringComparison.OrdinalIgnoreCase))
        {
            SetError("You cannot delete your own admin account.");
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;
        }

        _busy = true;
        ClearMessage();

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var persistedUser = await UserDb.GetByIdAsync(user.UserId);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (persistedUser == null)
            {
                SetError("User no longer exists.");
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                await ReloadUsersAsync();
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var persistedRole = NormalizeRole(persistedUser.Role);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (persistedRole == "admin")
            {
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                var adminCount = await UserDb.CountByRoleAsync("admin");
                // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
                if (adminCount <= 1)
                {
                    SetError("Cannot delete the last admin account.");
                    // החזרת התוצאה אל הקוד שקרא לפעולה.
                    return;
                }
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var outfits = await OutfitDb.GetByUserAsync(persistedUser.UserId, 2000);
            // לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים.
            foreach (var outfit in outfits)
            {
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                await OutfitGarmentDb.DeleteByOutfitIdAsync(outfit.OutfitId);
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                await OutfitDb.DeleteOutfitAsync(outfit.OutfitId);
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var garments = await GarmentDb.GetByUserAsync(persistedUser.UserId);
            // לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים.
            foreach (var garment in garments)
            {
                // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
                await GarmentDb.DeleteGarmentAsync(garment.GarmentId);
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var deleted = await UserDb.DeleteUserAsync(persistedUser.UserId);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (deleted <= 0)
            {
                SetError("Could not delete user.");
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await ReloadUsersAsync();
            SetSuccess("User and related data deleted.");
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            SetError($"Delete failed: {ex.Message}");
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _busy = false;
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private bool IsUserDirty(User user)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (string.IsNullOrWhiteSpace(user.UserId))
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return false;

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (!_originalUserSnapshot.TryGetValue(user.UserId, out var original))
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return false;

        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return !string.Equals(original, BuildUserSnapshot(user), StringComparison.Ordinal);
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static string BuildUserSnapshot(User user)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var email = (user.Email ?? string.Empty).Trim().ToLowerInvariant();
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var fullName = (user.FullName ?? string.Empty).Trim();
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var role = NormalizeRole(user.Role);
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return $"{email}|{fullName}|{role}";
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static string NormalizeRole(string? role)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var normalized = (role ?? string.Empty).Trim().ToLowerInvariant();
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return normalized == "admin" ? "admin" : "customer";
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void ClearMessage()
    {
        _message = string.Empty;
        _isError = false;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void SetSuccess(string message)
    {
        _message = message;
        _isError = false;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void SetError(string message)
    {
        _message = message;
        _isError = true;
    }
}
