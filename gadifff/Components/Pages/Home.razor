@* חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד. *@
@code {
    private bool _loaded;
    private User? _currentUser;
    private string _adminLoadError = string.Empty;

    private int _customerCount;
    private int _adminCount;
    private int _customerGarmentCount;
    private int _savedOutfitCount;

    // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
    private const int _chartDays = 14;
    // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
    private const double ChartXMin = 50d;
    // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
    private const double ChartXMax = 730d;
    // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
    private const double ChartYTop = 20d;
    // חלק תצוגה שמציג נתון או רכיב למשתמש ומתחבר למשתנים ולפעולות באזור הקוד.
    private const double ChartYBottom = 200d;
    private int _chartMaxValue = 1;
    private List<UsagePoint> _usage = new();
    private string _usersLinePoints = string.Empty;
    private string _garmentsLinePoints = string.Empty;
    private string _outfitsLinePoints = string.Empty;
    private List<ChartPoint> _usersChartPoints = new();
    private List<ChartPoint> _garmentsChartPoints = new();
    private List<ChartPoint> _outfitsChartPoints = new();
    private List<AxisTick> _yAxisTicks = new();
    private int _selectedUsageIndex = -1;
    private int _hoveredUsageIndex = -1;

    private double _chartStepX => _usage.Count > 1
        ? (ChartXMax - ChartXMin) / (_usage.Count - 1)
        : 56d;

    private int ActiveUsageIndex
    {
        get
        {
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_hoveredUsageIndex >= 0 && _hoveredUsageIndex < _usage.Count)
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return _hoveredUsageIndex;
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (_selectedUsageIndex >= 0 && _selectedUsageIndex < _usage.Count)
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return _selectedUsageIndex;
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return _usage.Count == 0 ? -1 : _usage.Count - 1;
        }
    }

    private UsagePoint? ActiveUsagePoint =>
        ActiveUsageIndex >= 0 && ActiveUsageIndex < _usage.Count
            ? _usage[ActiveUsageIndex]
            : null;

    private bool IsAdmin =>
        _currentUser?.Role?.Equals("admin", StringComparison.OrdinalIgnoreCase) == true;

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (!firstRender)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        _currentUser = await AuthService.CurrentUserAsync();
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsAdmin)
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await LoadAdminDashboardAsync();

        _loaded = true;
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await InvokeAsync(StateHasChanged);
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task LoadAdminDashboardAsync()
    {
        _adminLoadError = string.Empty;
        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            _customerCount = await UserDb.CountByRoleAsync("customer");
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            _adminCount = await UserDb.CountByRoleAsync("admin");
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            _customerGarmentCount = await GarmentDb.CountByUserRoleAsync("customer");
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            _savedOutfitCount = await OutfitDb.CountByUserRoleAsync("customer");

            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var usersByDay = await UserDb.GetDailyCreatedCountsAsync(_chartDays);
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var garmentsByDay = await GarmentDb.GetDailyCreatedCountsByUserRoleAsync(_chartDays, "customer");
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var outfitsByDay = await OutfitDb.GetDailyCreatedCountsByUserRoleAsync(_chartDays, "customer");

            BuildUsagePoints(
                usersByDay,
                garmentsByDay,
                outfitsByDay);
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            _adminLoadError = $"Could not load admin statistics: {ex.Message}";
        }
    }

    private void BuildUsagePoints(
        Dictionary<DateTime, int> usersByDay,
        Dictionary<DateTime, int> garmentsByDay,
        Dictionary<DateTime, int> outfitsByDay)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var today = DateTime.UtcNow.Date;
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var start = today.AddDays(-(_chartDays - 1));
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var points = new List<UsagePoint>(_chartDays);

        // לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים.
        for (var i = 0; i < _chartDays; i++)
        {
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var day = start.AddDays(i).Date;
            points.Add(new UsagePoint(
                day,
                usersByDay.GetValueOrDefault(day),
                garmentsByDay.GetValueOrDefault(day),
                outfitsByDay.GetValueOrDefault(day)));
        }

        _usage = points;
        _chartMaxValue = Math.Max(1, _usage.Max(x => Math.Max(x.UsersCreated, Math.Max(x.GarmentsAdded, x.OutfitsSaved))));
        _usersChartPoints = BuildChartPoints(_usage, x => x.UsersCreated, _chartMaxValue);
        _garmentsChartPoints = BuildChartPoints(_usage, x => x.GarmentsAdded, _chartMaxValue);
        _outfitsChartPoints = BuildChartPoints(_usage, x => x.OutfitsSaved, _chartMaxValue);
        _usersLinePoints = BuildLinePoints(_usersChartPoints);
        _garmentsLinePoints = BuildLinePoints(_garmentsChartPoints);
        _outfitsLinePoints = BuildLinePoints(_outfitsChartPoints);
        _yAxisTicks = BuildAxisTicks(_chartMaxValue, 4);
        _selectedUsageIndex = _usage.Count == 0 ? -1 : _usage.Count - 1;
        _hoveredUsageIndex = -1;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static List<ChartPoint> BuildChartPoints(
        IReadOnlyList<UsagePoint> points,
        Func<UsagePoint, int> selector,
        int maxValue)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (points.Count == 0)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return new List<ChartPoint>();

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var safeMax = Math.Max(1, maxValue);
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var step = points.Count > 1 ? (ChartXMax - ChartXMin) / (points.Count - 1) : 0d;
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var list = new List<ChartPoint>(points.Count);
        // לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים.
        for (var i = 0; i < points.Count; i++)
        {
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var value = Math.Clamp(selector(points[i]), 0, int.MaxValue);
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var ratio = value / (double)safeMax;
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var x = ChartXMin + (step * i);
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var y = ChartYBottom - ((ChartYBottom - ChartYTop) * ratio);
            list.Add(new ChartPoint(i, points[i].Day, value, x, y));
        }

        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return list;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static string BuildLinePoints(IReadOnlyList<ChartPoint> points)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (points.Count == 0)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return string.Empty;

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var culture = CultureInfo.InvariantCulture;
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return string.Join(' ', points.Select(x =>
            $"{x.X.ToString("0.##", culture)},{x.Y.ToString("0.##", culture)}"));
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static List<AxisTick> BuildAxisTicks(int maxValue, int sections)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var safeMax = Math.Max(1, maxValue);
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var safeSections = Math.Max(2, sections);
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var ticks = new List<AxisTick>(safeSections + 1);
        // לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים.
        for (var i = 0; i <= safeSections; i++)
        {
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var ratio = i / (double)safeSections;
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var y = ChartYBottom - ((ChartYBottom - ChartYTop) * ratio);
            // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
            var value = (int)Math.Round(safeMax * ratio);
            ticks.Add(new AxisTick(y, value));
        }

        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return ticks;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void SelectUsagePoint(int index)
    {
        _selectedUsageIndex = Math.Clamp(index, 0, Math.Max(0, _usage.Count - 1));
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void HoverUsagePoint(int index)
    {
        _hoveredUsageIndex = Math.Clamp(index, 0, Math.Max(0, _usage.Count - 1));
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void ClearUsageHover()
    {
        _hoveredUsageIndex = -1;
    }

    // הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת.
    private readonly record struct UsagePoint(
        DateTime Day,
        int UsersCreated,
        int GarmentsAdded,
        int OutfitsSaved);

    // הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת.
    private readonly record struct ChartPoint(
        int Index,
        DateTime Day,
        int Value,
        double X,
        double Y);

    // הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת.
    private readonly record struct AxisTick(
        double Y,
        int Value);
}
