@* מסלול תצוגת חלופי כשר התנאי הקודם לא התקיים. *@
else if (IsAdmin)
{
    <div class="page-shell">
        <div class="section-header">
            <div>
                <div class="section-title">Welcome, @_currentUser!.FullName</div>
                <div class="section-subtitle">Admin overview</div>
            </div>
            <div class="action-group">

                @* הגדרת מחלקה שמרכזת נתונים ופעולות שקשורים לאותו תפקיד במערכת. *@
                <button class="btn btn-outline-primary" @onclick="@(() => Nav.NavigateTo("/admin/closets"))">
                    Open admin section
                </button>
            </div>
        </div>


        @* בדיקת תנאי שקובעת איזה מסלול בקוד יפעל לפי המצב הנוכחי. *@
        @if (!string.IsNullOrWhiteSpace(_adminLoadError))
        {
            <div class="alert alert-warning">@_adminLoadError</div>
        }

        <div class="row g-3 mb-3">
            <div class="col-12 col-md-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small">Customers</div>
                        <div class="fs-3 fw-bold">@_customerCount</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small">Admins</div>
                        <div class="fs-3 fw-bold">@_adminCount</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small">Customer garments</div>
                        <div class="fs-3 fw-bold">@_customerGarmentCount</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small">Saved outfits</div>
                        <div class="fs-3 fw-bold">@_savedOutfitCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <div class="fw-bold mb-2">Usage chart (last @_chartDays days)</div>
                <div class="text-muted small mb-3">
                    Users created, customer garments added, and outfits saved per day.
                </div>
                <div class="usage-chart-layout">
                    <div class="usage-chart-visual">
                        <svg viewBox="0 0 760 250"
                             class="usage-chart-svg"
                             @onmouseleave="ClearUsageHover">

                            @* בדיקת תנאי שקובעת איזה מסלול בקוד יפעל לפי המצב הנוכחי. *@
                            @if (_yAxisTicks.Count > 0)
                            {

                                @* לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים. *@
                                @foreach (var tick in _yAxisTicks)
                                {
                                    <line x1="50" y1="@tick.Y" x2="730" y2="@tick.Y" class="usage-grid-line" />
                                }
                            }

                            <line x1="50" y1="20" x2="50" y2="200" class="usage-axis-line" />
                            <line x1="50" y1="200" x2="730" y2="200" class="usage-axis-line" />


                            @* בדיקת תנאי שקובעת איזה מסלול בקוד יפעל לפי המצב הנוכחי. *@
                            @if (_usersChartPoints.Count > 0 && ActiveUsageIndex >= 0 && ActiveUsageIndex < _usersChartPoints.Count)
                            {
                                var activeX = _usersChartPoints[ActiveUsageIndex].X;
                                <line x1="@activeX" y1="20" x2="@activeX" y2="200" class="usage-active-line" />
                            }


                            @* לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים. *@
                            @foreach (var point in _usersChartPoints)
                            {
                                var width = Math.Max(18d, _chartStepX);
                                var left = Math.Max(50d, point.X - (width / 2d));
                                var right = Math.Min(730d, point.X + (width / 2d));
                                <rect x="@left"
                                      y="20"
                                      width="@(right - left)"
                                      height="180"
                                      class="usage-hit-zone @(point.Index == ActiveUsageIndex ? "is-active" : string.Empty)"
                                      @onmouseover="() => HoverUsagePoint(point.Index)"

                                      @* הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה. *@
                                      @onclick="() => SelectUsagePoint(point.Index)" />
                            }

                            <polyline points="@_usersLinePoints" class="usage-line users" />
                            <polyline points="@_garmentsLinePoints" class="usage-line garments" />
                            <polyline points="@_outfitsLinePoints" class="usage-line outfits" />


                            @* לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים. *@
                            @foreach (var point in _usersChartPoints)
                            {
                                var isActive = point.Index == ActiveUsageIndex;
                                <circle cx="@point.X"
                                        cy="@point.Y"
                                        r="@(isActive ? 5.2 : 3.8)"
                                        class="usage-point users @(isActive ? "is-active" : string.Empty)"
                                        @onmouseover="() => HoverUsagePoint(point.Index)"

                                        @* הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה. *@
                                        @onclick="() => SelectUsagePoint(point.Index)">
                                    <title>@($"{point.Day:yyyy-MM-dd}: users {point.Value}")</title>
                                </circle>
                            }

                            @* לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים. *@
                            @foreach (var point in _garmentsChartPoints)
                            {
                                var isActive = point.Index == ActiveUsageIndex;
                                <circle cx="@point.X"
                                        cy="@point.Y"
                                        r="@(isActive ? 5.2 : 3.8)"
                                        class="usage-point garments @(isActive ? "is-active" : string.Empty)"
                                        @onmouseover="() => HoverUsagePoint(point.Index)"

                                        @* הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה. *@
                                        @onclick="() => SelectUsagePoint(point.Index)">
                                    <title>@($"{point.Day:yyyy-MM-dd}: garments {point.Value}")</title>
                                </circle>
                            }

                            @* לולאה שמבצעת את אותה פעולה עבור כל פריט ברשימה או כל עוד התנאי מתקיים. *@
                            @foreach (var point in _outfitsChartPoints)
                            {
                                var isActive = point.Index == ActiveUsageIndex;
                                <circle cx="@point.X"
                                        cy="@point.Y"
                                        r="@(isActive ? 5.2 : 3.8)"
                                        class="usage-point outfits @(isActive ? "is-active" : string.Empty)"
                                        @onmouseover="() => HoverUsagePoint(point.Index)"

                                        @* הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה. *@
                                        @onclick="() => SelectUsagePoint(point.Index)">
                                    <title>@($"{point.Day:yyyy-MM-dd}: outfits {point.Value}")</title>
                                </circle>
                            }

                        </svg>
                    </div>


                    @* בדיקת תנאי שקובעת איזה מסלול בקוד יפעל לפי המצב הנוכחי. *@
                    @if (ActiveUsagePoint is { } activePoint)
                    {
                        <div class="usage-chart-details">
                            <div class="usage-date">@activePoint.Day.ToString("dddd, MMM dd yyyy")</div>
                            <div class="usage-details-row">
                                <span class="dot users"></span>
                                <span>Users created</span>
                                <strong>@activePoint.UsersCreated</strong>
                            </div>
                            <div class="usage-details-row">
                                <span class="dot garments"></span>
                                <span>Garments added</span>
                                <strong>@activePoint.GarmentsAdded</strong>
                            </div>
                            <div class="usage-details-row">
                                <span class="dot outfits"></span>
                                <span>Outfits saved</span>
                                <strong>@activePoint.OutfitsSaved</strong>
                            </div>
                            <div class="usage-chart-max">Scale max: @_chartMaxValue</div>
                        </div>
                    }
                </div>

                <div class="d-flex gap-3 flex-wrap mt-2 small usage-legend">
                    <span><span class="legend-box users"></span> users</span>
                    <span><span class="legend-box garments"></span> garments</span>
                    <span><span class="legend-box outfits"></span> outfits</span>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="fw-bold mb-2">Daily usage</div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Users</th>
                                <th>Garments</th>
                                <th>Outfits</th>
                            </tr>
                        </thead>
                        <tbody>

                            @* הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה. *@
                            @foreach (var point in _usage.OrderByDescending(x => x.Day))
                            {
                                <tr>
                                    <td>@point.Day.ToString("yyyy-MM-dd")</td>
                                    <td>@point.UsersCreated</td>
                                    <td>@point.GarmentsAdded</td>
                                    <td>@point.OutfitsSaved</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

