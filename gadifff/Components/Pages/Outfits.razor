    // Opens one saved-outfit filter group inside the drawer.
    private void OpenOutfitFilterGroup(OutfitFilterGroup group)
    {
        _activeOutfitFilterGroup = group;
        _outfitFilterSearch = string.Empty;
    }

    // Returns from one filter group to the drawer summary list.
    private void BackToOutfitFilterGroups()
    {
        _activeOutfitFilterGroup = OutfitFilterGroup.None;
        _outfitFilterSearch = string.Empty;
