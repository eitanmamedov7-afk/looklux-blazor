        _previewImageUrl = null;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void StartNewMatch()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsReadOnlyAdminView)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _matcherGarments = _allGarments.ToList();
        _matcherRequest = string.Empty;
        _seedIds = new();
        _autoStart = false;
        _requireSeedSelection = true;
        _showMatcher = true;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void FindFromOutfit(Outfit outfit)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsReadOnlyAdminView)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var seeds = new List<string>();

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_outfitGarmentsByOutfit.TryGetValue(outfit.OutfitId, out var links) && links.Count > 0)
        {
            seeds.AddRange(links
                .Where(x => x.IsSeed && !string.IsNullOrWhiteSpace(x.GarmentId))
                .Select(x => x.GarmentId));
        }

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (seeds.Count == 0 && !string.IsNullOrWhiteSpace(outfit.RequestedGarmentIds))
        {
            seeds.AddRange(outfit.RequestedGarmentIds.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
        }

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (seeds.Count == 0)
        {
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (!string.IsNullOrEmpty(outfit.ShirtGarmentId)) seeds.Add(outfit.ShirtGarmentId);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (!string.IsNullOrEmpty(outfit.PantsGarmentId)) seeds.Add(outfit.PantsGarmentId);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (!string.IsNullOrEmpty(outfit.ShoesGarmentId)) seeds.Add(outfit.ShoesGarmentId);
        }

        _seedIds = seeds.Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        _matcherGarments = _allGarments.ToList();
        _matcherRequest = string.Empty;
        _autoStart = true;
        _requireSeedSelection = true;
        _showMatcher = true;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void ConfirmDeleteOutfitDialog(string outfitId)
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsReadOnlyAdminView)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (string.IsNullOrWhiteSpace(outfitId))
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _deleteOutfitId = outfitId;
        _deleteOutfitDialogMessage = string.Empty;
        _deleteOutfitDialogIsError = false;
        _deleteOutfitDialogBusy = false;
        _deleteOutfitDialogCompleted = false;
        _showDeleteOutfitDialog = true;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void CloseDeleteOutfitDialog()
    {
        _showDeleteOutfitDialog = false;
        _deleteOutfitId = null;
        _deleteOutfitDialogMessage = string.Empty;
        _deleteOutfitDialogIsError = false;
        _deleteOutfitDialogBusy = false;
        _deleteOutfitDialogCompleted = false;
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task DeleteOutfitConfirmedAsync()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsReadOnlyAdminView)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_user == null || string.IsNullOrWhiteSpace(_deleteOutfitId) || _deleteOutfitDialogBusy)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _deleteOutfitDialogBusy = true;
        _deleteOutfitDialogMessage = string.Empty;
        _deleteOutfitDialogIsError = false;
        _deleteOutfitDialogCompleted = false;

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await OutfitGarmentDb.DeleteByOutfitIdAsync(_deleteOutfitId);
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            var deleted = await OutfitDb.DeleteOutfitAsync(_deleteOutfitId);
            // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
            if (deleted <= 0)
            {
                _deleteOutfitDialogIsError = true;
                _deleteOutfitDialogMessage = "Could not delete this outfit.";
                // החזרת התוצאה אל הקוד שקרא לפעולה.
                return;
            }

            _deleteOutfitDialogMessage = "Outfit deleted.";
            _deleteOutfitDialogCompleted = true;
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await Reload();
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            _deleteOutfitDialogIsError = true;
            _deleteOutfitDialogMessage = $"Delete failed: {ex.Message}";
        }
        // ניקוי או סגירת משאבים שסרוצים בסוף הפעולה.
        finally
        {
            _deleteOutfitDialogBusy = false;
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await InvokeAsync(StateHasChanged);
        }
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void OpenBestRecommendationWindow()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsReadOnlyAdminView)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _bestRecommendationWindowError = string.Empty;
        _bestRecommendationRequest = string.Empty;
        _showBestRecommendationWindow = true;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void CloseBestRecommendationWindow()
    {
        _showBestRecommendationWindow = false;
        _bestRecommendationWindowError = string.Empty;
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task ApplyBestRecommendationFiltersAndRunAsync()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (IsReadOnlyAdminView)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _bestRecommendationWindowError = string.Empty;
        _showBestRecommendationWindow = false;
        _matcherGarments = _allGarments.ToList();
        _matcherRequest = string.IsNullOrWhiteSpace(_bestRecommendationRequest)
            ? string.Empty
            : _bestRecommendationRequest;
        _seedIds = new();
        _autoStart = true;
        _requireSeedSelection = false;
        _showMatcher = true;
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await InvokeAsync(StateHasChanged);
    }

    private string OutfitBestRecommendationActionLabel
    {
        get
        {
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return string.IsNullOrWhiteSpace(_bestRecommendationRequest)
                ? "Start without request"
                : "Start requested recommendation";
        }
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private Task CloseMatcher()
    {
        _showMatcher = false;
        _requireSeedSelection = true;
        _matcherGarments = _allGarments.ToList();
        _matcherRequest = string.Empty;
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return Task.CompletedTask;
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task Reload()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_user == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        // ניסיון להריץ פעולה שעלולה להיכשל, כדי שאפשר יהיה לטפל בכשל בצורה מסודרת.
        try
        {
            // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
            await LoadData();
        }
        // טיפול בשגיאה כדי להחזיר תוצאה בטוחה במקום קריסה.
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await InvokeAsync(StateHasChanged);
    }

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task RetryLoad()
    {
        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        await Reload();
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    public void Dispose()
    {
        _filterCts?.Cancel();
        _filterCts?.Dispose();
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static string NormalizeAsUserId(string? asUserId) =>
        (asUserId ?? string.Empty).Trim();

    // הגדרת פעולה אסינכרונית שמובצעת מול שירות, דיבי או תצצוגה בלי לחסום את ההרצה.
    private async Task ResolveActiveUserContextAsync()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_user == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _resolvedAsUserId = NormalizeAsUserId(AsUserId);
        _activeUserId = _user.UserId;
        _activeUserDisplayName = string.IsNullOrWhiteSpace(_user.FullName)
            ? (_user.Email ?? "current user")
            : _user.FullName;
        _isAdminActingOnAnotherUser = false;

        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (string.IsNullOrWhiteSpace(_resolvedAsUserId) ||
            !string.Equals(_user.Role, "admin", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(_resolvedAsUserId, _user.UserId, StringComparison.OrdinalIgnoreCase))
        {
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;
        }

        // המתנה לפעולה אסינכרונית כדי להמשיך רק אחרי שהפעולה הסתיימה.
        var targetUser = await UserDb.GetByIdAsync(_resolvedAsUserId);
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (targetUser == null)
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;

        _activeUserId = targetUser.UserId;
        _activeUserDisplayName = string.IsNullOrWhiteSpace(targetUser.FullName)
            ? (targetUser.Email ?? "selected user")
            : targetUser.FullName;
        _isAdminActingOnAnotherUser = true;
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void OpenActiveUserCloset()
    {
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (_isAdminActingOnAnotherUser && !string.IsNullOrWhiteSpace(ActiveUserId))
        {
            Nav.NavigateTo($"/closet?asUserId={Uri.EscapeDataString(ActiveUserId)}");
            // החזרת התוצאה אל הקוד שקרא לפעולה.
            return;
        }

        Nav.NavigateTo("/closet");
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private void ExitAdminActingMode()
    {
        Nav.NavigateTo("/outfits");
    }

    // הגדרת פעולה שמרכזת שלב ברור בלוגיקה ומופעלת כאשר המסך או השירות צריך את התוצאה שלה.
    private static string NormalizeTypeName(string? type)
    {
        // יצירת משתנה מקומי שמכין ערך ביניים להמשך הפעולה.
        var value = (type ?? string.Empty).Trim().ToLowerInvariant();
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (string.IsNullOrEmpty(value)) return string.Empty;
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (value.Contains("shirt") || value.Contains("tee")) return "shirt";
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (value.Contains("pant") || value.Contains("trouser") || value.Contains("jean")) return "pants";
        // בדיקת תנאי שמוחליטה האם להמשיך, לעהצור או לעבור למסלול אחר.
        if (value.Contains("shoe") || value.Contains("sneaker") || value.Contains("boot")) return "shoes";
        // החזרת התוצאה אל הקוד שקרא לפעולה.
        return value;
    }

    // הגדרת מבנה מרכזי שמרכז נתונים או פעוליות עובר החלק הזה בפרויקט.
    private enum OutfitFilterGroup
    {
        None,
        Score,
        SeedType,
        Style,
        Occasion,
        Season,
        Place
    }
}
