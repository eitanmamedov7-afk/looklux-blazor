    // Topic: Load web outfit wear summaries
    // Purpose: Adds wear count, first worn, and last worn data to the loaded outfit cards.
    // Search keywords: OUTFIT_WEAR_LOG WEB OUTFIT LIST HISTORY COUNT TIMESTAMP
    // When to use it: Run after outfit rows load or after a new wear log is inserted.
    // Important notes: Summary values are calculated from outfit_wear_logs, not from the outfits table.
    // FLOW_OUTFIT_WEAR_STATS_01: Outfits page asks OutfitWearLogDB for summaries for the currently loaded outfits.
    // This page is involved because it owns the filtered outfit list; next step is DB aggregation.
    private async Task LoadWearSummariesAsync()
    {
        var summaries = await OutfitWearLogDb.GetSummariesByOutfitIdsAsync(_outfits.Select(x => x.OutfitId));
        ApplyWearSummaries(_outfits, summaries);
    }

    // Topic: Apply outfit wear summaries
    // Purpose: Copies calculated count/first/last values onto each Outfit model before rendering.
    // Search keywords: OUTFIT_WEAR_LOG WEB OUTFIT LIST HISTORY COUNT TIMESTAMP
    // When to use it: Use after DB aggregation returns summary values.
    // Important notes: Outfits with no logs show zero wears.
    // FLOW_OUTFIT_WEAR_STATS_04: Summary values are copied onto Outfit models for rendering/API serialization.
    // This page is involved because the web UI renders these model properties directly; next step is card display.
    private static void ApplyWearSummaries(IEnumerable<Outfit> outfits, IReadOnlyDictionary<string, OutfitWearLog> summaries)
    {
        foreach (var outfit in outfits)
        {
            if (summaries.TryGetValue(outfit.OutfitId, out var summary))
            {
                outfit.WearCount = summary.WearCount;
                outfit.FirstWornAt = summary.FirstWornAt;
                outfit.LastWornAt = summary.LastWornAt;
            }
            else
            {
                outfit.WearCount = 0;
                outfit.FirstWornAt = null;
                outfit.LastWornAt = null;
            }
        }
    }

    // Formats the outfit wear summary shown on every outfit card.
    private static string FormatWearSummary(Outfit outfit)
    {
        if (outfit.WearCount <= 0)
            return "Worn 0 times";

        var first = outfit.FirstWornAt?.ToLocalTime().ToString("g") ?? "unknown";
        var last = outfit.LastWornAt?.ToLocalTime().ToString("g") ?? "unknown";
        return $"Worn {outfit.WearCount} time{(outfit.WearCount == 1 ? "" : "s")} | First: {first} | Last: {last}";
    }

    // Function role:
    // Opens matcher without seeds so the user can start a fresh recommendation.
    private void StartNewMatch()
    {
        if (IsReadOnlyAdminView)
            return;

        _matcherGarments = _allGarments.ToList();
        _matcherRequest = string.Empty;
        _seedIds = new();
        _autoStart = false;
        _requireSeedSelection = true;
        _showMatcher = true;
    }

    // Function role:
    // Reopens matcher using a saved outfit's seed/requested garments as the starting point.
    private void FindFromOutfit(Outfit outfit)
    {
        if (IsReadOnlyAdminView)
            return;

        var seeds = new List<string>();

        if (_outfitGarmentsByOutfit.TryGetValue(outfit.OutfitId, out var links) && links.Count > 0)
        {
            seeds.AddRange(links
                .Where(x => x.IsSeed && !string.IsNullOrWhiteSpace(x.GarmentId))
                .Select(x => x.GarmentId));
        }

        if (seeds.Count == 0 && !string.IsNullOrWhiteSpace(outfit.RequestedGarmentIds))
        {
            seeds.AddRange(outfit.RequestedGarmentIds.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
        }

        if (seeds.Count == 0)
        {
            if (!string.IsNullOrEmpty(outfit.ShirtGarmentId)) seeds.Add(outfit.ShirtGarmentId);
            if (!string.IsNullOrEmpty(outfit.PantsGarmentId)) seeds.Add(outfit.PantsGarmentId);
            if (!string.IsNullOrEmpty(outfit.ShoesGarmentId)) seeds.Add(outfit.ShoesGarmentId);
        }

        _seedIds = seeds.Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        _matcherGarments = _allGarments.ToList();
        _matcherRequest = string.Empty;
        _autoStart = true;
        _requireSeedSelection = true;
        _showMatcher = true;
    }

    // Topic: Mark outfit worn from web
    // Purpose: Stores the current server timestamp for the selected saved outfit.
    // Search keywords: OUTFIT_WEAR_LOG WEB OUTFIT ADD TIMESTAMP
    // When to use it: Use when explaining how a customer records that an outfit was just worn.
    // Important notes: Admin accounts cannot mark outfits as worn.
    // FLOW_OUTFIT_WEAR_WEB_02: MarkOutfitWornAsync validates the visible outfit and calls OutfitWearLogDB.
    // This file is involved because it owns the clicked outfit card and active user/admin target; next step is OutfitWearLogDB.MarkWornAsync.
    private async Task MarkOutfitWornAsync(string outfitId)
    {
        if (_user == null ||
            string.Equals(_user.Role, "admin", StringComparison.OrdinalIgnoreCase) ||
            string.IsNullOrWhiteSpace(ActiveUserId) ||
            _wearLogBusy)
            return;

        _wearLogMessage = string.Empty;
        _wearLogIsError = false;

        var outfitBelongsToActiveView = _outfits.Any(x =>
            string.Equals(x.OutfitId, outfitId, StringComparison.OrdinalIgnoreCase));

        if (!outfitBelongsToActiveView)
        {
            _wearLogIsError = true;
            _wearLogMessage = "This outfit is not loaded for the current user.";
            return;
        }

        try
        {
            _wearLogBusy = true;
            await OutfitWearLogDb.MarkWornAsync(ActiveUserId, outfitId);
            await LoadWearSummariesAsync();
            _wearLogMessage = $"Outfit marked as worn at {DateTime.Now:g}.";
        }
        catch (Exception ex)
        {
            _wearLogIsError = true;
            _wearLogMessage = $"Could not mark outfit as worn: {ex.Message}";
        }
        finally
        {
            _wearLogBusy = false;
        }
    }

