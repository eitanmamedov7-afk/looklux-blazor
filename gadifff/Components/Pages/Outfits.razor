    // Function role:
    // Reloads outfit data after save/delete or retry.
    // FLOW_OUTFIT_VIEW_WEB_02: Reload/LoadData asks OutfitDB for saved outfits and redraws cards.
    // This page is involved because it is the saved-outfits screen; next step is OutfitDB/OutfitGarmentDB data.
    private async Task Reload()
    {
        if (_user == null)
            return;

        try
        {
            await LoadData();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }

        await InvokeAsync(StateHasChanged);
    }

    // Retry button handler for load errors; reloads garments/outfits.
    private async Task RetryLoad()
    {
        await Reload();
    }

    // Function role:
