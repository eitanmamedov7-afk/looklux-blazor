    // Cleans the admin asUserId query parameter before comparison/loading.
    private static string NormalizeAsUserId(string? asUserId) =>
        (asUserId ?? string.Empty).Trim();

    // Function role:
    // Decides whether this page uses the logged-in user or admin-selected customer.
    // FLOW_ADMIN_VIEW_CUSTOMER_WEB_04: Outfits.razor reads asUserId and resolves the selected customer's read-only outfits.
    // This page is involved because admin reuses the normal outfits page safely; next step is OutfitDB.GetByUserAsync.
    private async Task ResolveActiveUserContextAsync()
    {
        if (_user == null)
            return;

        _resolvedAsUserId = NormalizeAsUserId(AsUserId);
        _activeUserId = _user.UserId;
        _activeUserDisplayName = string.IsNullOrWhiteSpace(_user.FullName)
            ? (_user.Email ?? "current user")
            : _user.FullName;
        _isAdminActingOnAnotherUser = false;

        if (string.IsNullOrWhiteSpace(_resolvedAsUserId) ||
            !string.Equals(_user.Role, "admin", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(_resolvedAsUserId, _user.UserId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var targetUser = await UserDb.GetByIdAsync(_resolvedAsUserId);
        if (targetUser == null)
            return;

        _activeUserId = targetUser.UserId;
        _activeUserDisplayName = string.IsNullOrWhiteSpace(targetUser.FullName)
            ? (targetUser.Email ?? "selected user")
            : targetUser.FullName;
        _isAdminActingOnAnotherUser = true;
    }

    // Function role:
    // Lets admins jump from a customer's outfits to that customer's read-only closet page.
    private void OpenActiveUserCloset()
    {
        if (_isAdminActingOnAnotherUser && !string.IsNullOrWhiteSpace(ActiveUserId))
        {
            Nav.NavigateTo($"/closet?asUserId={Uri.EscapeDataString(ActiveUserId)}");
            return;
        }

        Nav.NavigateTo("/closet");
    }

    // Leaves admin read-only mode and returns to the admin's own outfits page.
    private void ExitAdminActingMode()
    {
        Nav.NavigateTo("/outfits");
    }

    // Function role:
    // Normalizes garment type labels for outfit badges and fallback display.
    private static string NormalizeTypeName(string? type)
    {
        var value = (type ?? string.Empty).Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(value)) return string.Empty;
        if (value.Contains("shirt") || value.Contains("tee")) return "shirt";
        if (value.Contains("pant") || value.Contains("trouser") || value.Contains("jean")) return "pants";
        if (value.Contains("shoe") || value.Contains("sneaker") || value.Contains("boot")) return "shoes";
        return value;
    }

