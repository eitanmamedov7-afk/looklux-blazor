    // Opens the mobile-style drawer used to filter saved outfits.
    // FLOW_OUTFIT_FILTER_WEB_01: User clicks the saved-outfit Filters button and opens the drawer.
    // This page is involved because outfit filter selection starts in the UI; next step is filter changes and RefreshOutfitFiltersAsync.
    private void OpenOutfitFilterDrawer()
    {
        if (!ShouldShowOutfitFilters)
            return;

        _showOutfitFilterDrawer = true;
        _activeOutfitFilterGroup = OutfitFilterGroup.None;
        _outfitFilterSearch = string.Empty;
