        _deleteOutfitDialogIsError = false;
        _deleteOutfitDialogBusy = false;
        _deleteOutfitDialogCompleted = false;
    }

    // Function role:
    // Deletes outfit_garments links first, then deletes the saved outfit row.
    // FLOW_DELETE_OUTFIT_WEB_02: DeleteOutfitConfirmedAsync runs after user confirms the saved-outfit delete modal.
    // This page is involved because delete starts from an outfit card; next step is OutfitGarmentDB.DeleteByOutfitIdAsync.
    private async Task DeleteOutfitConfirmedAsync()
    {
        if (IsReadOnlyAdminView)
            return;

        if (_user == null || string.IsNullOrWhiteSpace(_deleteOutfitId) || _deleteOutfitDialogBusy)
            return;

        _deleteOutfitDialogBusy = true;
        _deleteOutfitDialogMessage = string.Empty;
        _deleteOutfitDialogIsError = false;
        _deleteOutfitDialogCompleted = false;

        try
        {
            await OutfitGarmentDb.DeleteByOutfitIdAsync(_deleteOutfitId);
            var deleted = await OutfitDb.DeleteOutfitAsync(_deleteOutfitId);
            if (deleted <= 0)
            {
                _deleteOutfitDialogIsError = true;
                _deleteOutfitDialogMessage = "Could not delete this outfit.";
                return;
            }

            _deleteOutfitDialogMessage = "Outfit deleted.";
            _deleteOutfitDialogCompleted = true;
            await Reload();
        }
        catch (Exception ex)
        {
            _deleteOutfitDialogIsError = true;
            _deleteOutfitDialogMessage = $"Delete failed: {ex.Message}";
        }
        finally
        {
            _deleteOutfitDialogBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

